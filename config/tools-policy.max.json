{
  "allowedPaths": [
    "."
  ],
  "deniedPaths": [
    ".git",
    ".env"
  ],
  "allowedDomains": [],
  "deniedDomains": [],
  "maxTimeoutMs": 300000,
  "maxResponseBytes": 2097152,
  "exec": {
    "quickTimeoutMs": 10000,
    "longTimeoutMs": 900000,
    "quickCommands": [
      "git",
      "ls",
      "dir",
      "rg",
      "fd",
      "jq",
      "curl",
      "whoami",
      "pwd",
      "cat",
      "type",
      "hostname",
      "tasklist",
      "where",
      "ping",
      "ipconfig"
    ],
    "longCommands": [
      "node",
      "npm",
      "pnpm",
      "yarn",
      "npx",
      "python",
      "python3",
      "pip",
      "pip3",
      "pipenv",
      "conda",
      "pytest",
      "pipx",
      "poetry",
      "cmake",
      "cargo",
      "go",
      "java",
      "mvn",
      "dotnet",
      "powershell",
      "powershell.exe",
      "pwsh",
      "docker",
      "podman",
      "kubectl",
      "helm",
      "terraform",
      "ffmpeg",
      "magick",
      "pandoc",
      "codex",
      "claude"
    ],
    "extraSafelist": [
      "docker",
      "podman",
      "kubectl",
      "helm",
      "terraform",
      "codex",
      "claude"
    ],
    "extraBlocklist": [
      "prettier",
      "black",
      "dotnet-format",
      "goimports"
    ],
    "nonInteractive": {
      "enabled": true,
      "rules": {
        "npm init": "-y",
        "pnpm dlx": "--yes",
        "conda install": "-y"
      }
    }
  },
  "fileWrite": {
    "allowedExtensions": [],
    "allowDotFiles": true,
    "allowBinary": true
  }
}

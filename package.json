{
  "name": "belldandy",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.23.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "build": "tsc -b",
    "bdd": "node --import tsx packages/belldandy-core/src/bin/bdd.ts",
    "start": "node packages/belldandy-core/dist/bin/bdd.js start",
    "dev": "node --import tsx packages/belldandy-core/src/bin/bdd.ts dev",
    "dev:gateway": "node --import tsx packages/belldandy-core/src/bin/bdd.ts dev",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^22.13.1",
    "@types/ws": "^8.18.1",
    "puppeteer-core": "^24.36.1",
    "tsx": "^4.20.5",
    "typescript": "^5.7.3",
    "vitest": "^2.1.9",
    "ws": "^8.19.0"
  }
}
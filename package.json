{
  "name": "belldandy",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.23.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "version:generate": "node --import tsx scripts/generate-version.ts",
    "prebuild": "pnpm run version:generate",
    "predev": "pnpm run version:generate",
    "pretest": "pnpm run version:generate",
    "build": "tsc -b",
    "postbuild": "node -e \"fs.cpSync('packages/belldandy-agent/src/templates', 'packages/belldandy-agent/dist/templates', {recursive:true, force:true})\"",
    "bdd": "node --import tsx packages/belldandy-core/src/bin/bdd.ts",
    "start": "node packages/belldandy-core/dist/bin/bdd.js start",
    "dev": "node --import tsx packages/belldandy-core/src/bin/bdd.ts dev",
    "dev:gateway": "node --import tsx packages/belldandy-core/src/bin/bdd.ts dev",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^22.13.1",
    "@types/ws": "^8.18.1",
    "puppeteer-core": "^24.36.1",
    "tsx": "^4.20.5",
    "typescript": "^5.7.3",
    "vitest": "^2.1.9",
    "ws": "^8.19.0"
  }
}

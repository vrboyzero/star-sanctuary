{
  "name": "star-sanctuary",
  "version": "0.2.2",
  "private": true,
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.23.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "clean:build": "node scripts/clean-build-artifacts.mjs",
    "clean:release-artifacts": "node scripts/clean-release-artifacts.mjs",
    "clean:release-artifacts:all": "node scripts/clean-release-artifacts.mjs --purge-cache",
    "version:generate": "node scripts/generate-version.mjs",
    "prebuild": "pnpm run version:generate",
    "predev": "pnpm run version:generate",
    "pretest": "pnpm run version:generate",
    "build:force": "tsc -b --force",
    "verify:build": "node scripts/verify-workspace-build.mjs",
    "verify:webchat": "node scripts/verify-webchat-modules.mjs",
    "build": "pnpm run build:force && pnpm run verify:build",
    "build:portable": "node packages/star-sanctuary-distribution/scripts/build-portable.mjs",
    "build:portable:full": "node packages/star-sanctuary-distribution/scripts/build-portable.mjs --mode full",
    "prefetch:portable": "node packages/star-sanctuary-distribution/scripts/prefetch-portable-deps.mjs",
    "prefetch:portable:full": "node packages/star-sanctuary-distribution/scripts/prefetch-portable-deps.mjs --mode full",
    "build:single-exe": "node packages/star-sanctuary-distribution/scripts/build-single-exe.mjs --mode full",
    "build:single-exe:full": "node packages/star-sanctuary-distribution/scripts/build-single-exe.mjs --mode full",
    "smoke:portable": "node packages/star-sanctuary-distribution/scripts/smoke-portable.mjs",
    "smoke:portable:full": "node packages/star-sanctuary-distribution/scripts/smoke-portable.mjs --mode full",
    "smoke:single-exe": "node packages/star-sanctuary-distribution/scripts/smoke-single-exe.mjs --mode full",
    "smoke:single-exe:full": "node packages/star-sanctuary-distribution/scripts/smoke-single-exe.mjs --mode full",
    "verify:portable-lifecycle": "node packages/star-sanctuary-distribution/scripts/verify-portable-lifecycle.mjs",
    "verify:portable-lifecycle:full": "node packages/star-sanctuary-distribution/scripts/verify-portable-lifecycle.mjs --mode full",
    "verify:single-exe-lifecycle": "node packages/star-sanctuary-distribution/scripts/verify-single-exe-lifecycle.mjs --mode full",
    "verify:single-exe-lifecycle:full": "node packages/star-sanctuary-distribution/scripts/verify-single-exe-lifecycle.mjs --mode full",
    "verify:portable-deps": "node packages/star-sanctuary-distribution/scripts/verify-portable-deps.mjs",
    "verify:portable-deps:full": "node packages/star-sanctuary-distribution/scripts/verify-portable-deps.mjs --mode full",
    "verify:single-exe-deps": "node packages/star-sanctuary-distribution/scripts/verify-single-exe-deps.mjs --mode full",
    "verify:single-exe-deps:full": "node packages/star-sanctuary-distribution/scripts/verify-single-exe-deps.mjs --mode full",
    "rebuild": "pnpm run clean:build && pnpm run build",
    "postbuild": "node -e \"fs.cpSync('packages/belldandy-agent/src/templates', 'packages/belldandy-agent/dist/templates', {recursive:true, force:true})\"",
    "bdd": "node --import tsx packages/belldandy-core/src/bin/bdd.ts",
    "start": "node packages/belldandy-core/dist/bin/bdd.js start",
    "dev": "node --import tsx packages/belldandy-core/src/bin/bdd.ts dev",
    "dev:gateway": "node --import tsx packages/belldandy-core/src/bin/bdd.ts dev",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^22.13.1",
    "@types/ws": "^8.18.1",
    "esbuild": "^0.25.10",
    "postject": "^1.0.0-alpha.6",
    "puppeteer-core": "^24.36.1",
    "tsx": "^4.20.5",
    "typescript": "^5.7.3",
    "vitest": "^2.1.9",
    "ws": "^8.19.0"
  }
}

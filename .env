# ============================================
# Star Sanctuary 环境变量配置模板
# 复制此文件为 .env.local 并填写实际值
# ============================================
# ========================================
# Docker 镜像配置（仅 Docker 部署需要）
# ========================================
BELLDANDY_IMAGE=vrboyzero/star-sanctuary:local

# 网络配置

# ------ 服务配置 ------
# Gateway 服务端口（默认 28889）
BELLDANDY_PORT=28889
BELLDANDY_GATEWAY_PORT=28889  # Docker Compose 使用此变量

# 绑定地址（默认 127.0.0.1，设置为 0.0.0.0 可局域网访问）
# BELLDANDY_HOST=127.0.0.1

# 状态目录（Windows / WSL 分离策略）
BELLDANDY_STATE_DIR_WINDOWS=C:\Users\admin\.star_sanctuary
BELLDANDY_STATE_DIR_WSL=~/.star_sanctuary
# 额外允许 Agent 读写的根目录，逗号分隔（如其他盘符下的目录），不设则仅限上面状态目录
BELLDANDY_EXTRA_WORKSPACE_ROOTS="C:\Users\admin\Pictures,E:\,C:\Users\admin\.star_sanctuary"

# ------ 鉴权配置 ------
# 鉴权模式: none | token | password（默认 none）
# 注意：即使是 none，新设备连接也需要 Pairing 配对
BELLDANDY_AUTH_MODE=none
# 当 AUTH_MODE=token 时必填
# BELLDANDY_AUTH_TOKEN=your-secret-token
# 当 AUTH_MODE=password 时必填
# BELLDANDY_AUTH_PASSWORD=your-password

# Community API（/api/message）配置
# 默认关闭；开启后必须在请求头携带 Authorization: Bearer <token>
# 安全约束：当 BELLDANDY_COMMUNITY_API_ENABLED=true 时，BELLDANDY_AUTH_MODE 不能为 none（建议 token）
BELLDANDY_COMMUNITY_API_ENABLED=false
# 社区 API 专用 token（推荐单独设置）；未设置时会回退到 BELLDANDY_AUTH_TOKEN
# BELLDANDY_COMMUNITY_API_TOKEN=your-community-api-token
# 调用示例：
# curl -X POST http://127.0.0.1:28889/api/message -H "Authorization: Bearer your-community-api-token" -H "Content-Type: application/json" -d "{\"text\":\"hello\",\"conversationId\":\"conv-1\"}"

# Token 消耗上传到 office.goddess.ai（默认关闭）
# 作用：把每次新增的 token 消耗（delta）上报给 office 的 /api/internal/token-usage
# 使用步骤（通俗版）：
# 1) 先把 ENABLED 改成 true
# 2) URL 填 office 后端地址（通常是 http://127.0.0.1:3001/api/internal/token-usage）
# 3) APIKEY 填“该用户在 office.goddess.ai 里生成的 API Key 明文（gro_...）”
# 4) Belldandy 会自动带请求头：Authorization: Bearer <APIKEY>
# 5) office 后端会用这个 API Key 反查归属用户并累计到该用户账号
# BELLDANDY_TOKEN_USAGE_UPLOAD_ENABLED=true
# 接收端接口（office 内部路由）
# BELLDANDY_TOKEN_USAGE_UPLOAD_URL=http://127.0.0.1:3001/api/internal/token-usage
# 上传鉴权 API Key（推荐：每用户独立 key，便于单独吊销）
# BELLDANDY_TOKEN_USAGE_UPLOAD_APIKEY=gro_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 上传超时（毫秒，默认 3000）
# BELLDANDY_TOKEN_USAGE_UPLOAD_TIMEOUT_MS=3000

# WebSocket Origin 白名单（逗号分隔，防 CSWSH 攻击）
# 作用：限制哪些网页/客户端可以连接到 Belldandy Gateway
# 默认行为：若不设置，本地开发环境（HOST=127.0.0.1）自动允许 localhost/127.0.0.1
BELLDANDY_ALLOWED_ORIGINS=http://127.0.0.1:28889
# 配置建议：
# - 纯本地使用（命令行）：不需要配置
# - 本地 Web 开发：BELLDANDY_ALLOWED_ORIGINS=http://localhost:5173
# - 公网部署/生产环境：BELLDANDY_ALLOWED_ORIGINS=https://console.belldandy.ai
# BELLDANDY_ALLOWED_ORIGINS=http://localhost:3000,https://app.example.com
# 多个地址用英文逗号 , 分隔

# ========================================
# WebChat 附件限制
# ========================================
# 单个附件大小上限（字节，默认 10MB）
BELLDANDY_ATTACHMENT_MAX_FILE_BYTES=31457280

# 单次消息所有附件总大小上限（字节，默认 30MB）
BELLDANDY_ATTACHMENT_MAX_TOTAL_BYTES=62914560

# 单个文本附件注入 prompt 的字符上限
# 建议值：12 万字符，保留长文档可读性，同时避免单文件直接吃掉过多上下文
BELLDANDY_ATTACHMENT_TEXT_CHAR_LIMIT=120000

# 单次消息所有文本附件 + 音频转录注入 prompt 的总字符预算
# 建议值：16 万字符，和当前较高的 MAX_INPUT_TOKENS / TIMEOUT 风格保持一致，但避免多附件线性放大
BELLDANDY_ATTACHMENT_TEXT_TOTAL_CHAR_LIMIT=160000

# 当用户已有文本输入时，单个音频转录作为追加上下文写入 prompt 的字符上限
# 建议值：8000 字符，足够覆盖长语音关键信息，避免 transcript 抢占正文上下文
BELLDANDY_AUDIO_TRANSCRIPT_APPEND_CHAR_LIMIT=8000

# Agent 提供商（mock | openai，默认 mock）
BELLDANDY_AGENT_PROVIDER=openai

# 流式输出（默认 true）
BELLDANDY_OPENAI_STREAM=true
# 单次模型调用超时（毫秒，默认 120000 即 2 分钟）
BELLDANDY_AGENT_TIMEOUT_MS=300000

# OpenAI 线路协议：chat_completions（默认）| responses
# 使用 aicodewith 的 gpt-5.3-codex 时通常需要设置为 responses
# BELLDANDY_OPENAI_WIRE_API=responses
# OpenAI 默认重试次数（不含首次请求，默认 0）
# 仅对可重试错误生效（timeout/429/5xx/网络异常）
BELLDANDY_OPENAI_MAX_RETRIES=1
# OpenAI 默认重试退避基线（毫秒，默认 300）
# 实际退避采用指数退避，最大约 5 秒
# BELLDANDY_OPENAI_RETRY_BACKOFF_MS=1000
# OpenAI primary 专用代理 URL（可选）
# 用于网络受限场景；fallback 可在 models.json 里按模型单独覆盖 proxyUrl
# BELLDANDY_OPENAI_PROXY_URL=http://127.0.0.1:7890
# 启动时 primary 预热探测（失败会给 primary 加短期冷却，默认 true）
# BELLDANDY_PRIMARY_WARMUP_ENABLED=true
# 预热探测请求超时（毫秒，默认 8000）
# BELLDANDY_PRIMARY_WARMUP_TIMEOUT_MS=8000
# 预热失败后 primary 的冷却时间（毫秒，默认 60000）
# BELLDANDY_PRIMARY_WARMUP_COOLDOWN_MS=60000


# ------ 工具与能力 ------
# 启用工具调用（联网、读写文件等,false/true）
BELLDANDY_TOOLS_ENABLED=true
# 仅在 responses + tools 模式下清洗工具 schema，移除 oneOf/$ref 等不兼容关键字
# 某些代理（如部分 aicodewith 路由）在 tools 模式下需要开启
BELLDANDY_RESPONSES_SANITIZE_TOOL_SCHEMA=true

# Agent 是否可控制已注册工具的全局 disabled 列表
# - disabled: 禁止 Agent 修改工具开关
# - confirm: Agent 发起后，需用户回复固定文本口令确认
# - auto: Agent 可直接修改全局工具开关
BELLDANDY_AGENT_TOOL_CONTROL_MODE=confirm

# 工具开关确认密码（仅在 BELLDANDY_AGENT_TOOL_CONTROL_MODE=confirm 时生效）
# - 留空：沿用“批准工具设置变更 <requestId>”确认口令
# - 已设置：用户改为输入这里配置的确认口令；系统不会回显该口令
# BELLDANDY_AGENT_TOOL_CONTROL_CONFIRM_PASSWORD=

# 工具分组加载（默认 all 加载全部，逗号分隔可选组）
# 可选组：browser（浏览器自动化）, multimedia（摄像头/图片生成/TTS）, methodology（方法论SOP）, system（日志/定时任务/重启/模组切换）
# core 组（file/fetch/memory/apply_patch）始终加载，无需指定
# 使用中转代理时建议只加载需要的组以减少 token 消耗
# 示例：BELLDANDY_TOOL_GROUPS=core（只加载核心工具）
# 示例：BELLDANDY_TOOL_GROUPS=browser,system（加载核心+浏览器+系统工具）
BELLDANDY_TOOL_GROUPS=all

# 最大输入 token 数限制（超过时自动裁剪历史消息，0 或不设表示不限制）
# 使用有输入长度限制的中转代理时建议设置，如 BELLDANDY_MAX_INPUT_TOKENS=20000
# BELLDANDY_MAX_INPUT_TOKENS=20000
# 默认值
BELLDANDY_MAX_INPUT_TOKENS=120000

# 单次模型调用最大输出 token 数（默认 4096）
# 建议调大到 8192 或更高，避免模型在生成长内容（如大型工具调用 JSON）时被截断
# 如果你用的是 Kimi K2.5 或 Claude，可以直接设 16384
# 截断会导致工具参数残缺，引发 file_write "path 必须是非空字符串" 等错误
BELLDANDY_MAX_OUTPUT_TOKENS=16384

# 启用危险工具（run_command 等，默认 false）
# ⚠️ 仅在受信任环境下启用，允许执行任意命令
# 注：启用后命令执行仍受下方 TOOLS_POLICY_FILE 中 exec 规则约束（超时、白名单等）
BELLDANDY_DANGEROUS_TOOLS_ENABLED=true

# 工具策略配置文件（JSON），用于覆盖默认的工具策略
# tools-policy.json位于你安装的\star-sanctuary\config\tools-policy.json
# 示例：E:\\project\\star-sanctuary\\config\\tools-policy.json
BELLDANDY_TOOLS_POLICY_FILE=E:\\project\\star-sanctuary\\config\\tools-policy.json
# 示例内容（JSON）：
# {
#   "allowedPaths": ["workspace", "notes"],
#   "deniedPaths": [".git", "node_modules", ".env"],
#   "exec": {
#     "quickTimeoutMs": 5000,
#     "longTimeoutMs": 300000,
#     "extraSafelist": ["terraform", "docker", "podman", "kubectl", "helm"],
#     "extraBlocklist": [],
#     "nonInteractive": {
#       "enabled": true,
#       "rules": {
#         "npm init": "-y",
#         "conda install": "-y"
#       }
#     }
#   }
# }

# ------ 记忆与向量检索 ------
# 启用向量搜索（需要 Embedding 模型）
# 模型会自动下载并保存到 ~/.star_sanctuary/models 文件夹中
BELLDANDY_EMBEDDING_ENABLED=true
# Embedding 提供商选择: openai | local (默认是 openai)
BELLDANDY_EMBEDDING_PROVIDER=openai
# 本地模型名称 (仅当 provider=local 时生效)
# 支持的模型: BAAI/bge-base-en-v1.5, BAAI/bge-small-en-v1.5 等
# 注意: fastembed npm 包暂不支持 bge-m3，请使用上述模型
# BELLDANDY_LOCAL_EMBEDDING_MODEL=BAAI/bge-base-en-v1.5
# 如果您的 Embedding 服务使用不同的 Key/BaseURL，请在此配置；否则默认使用上方的通用配置
# BELLDANDY_EMBEDDING_OPENAI_API_KEY="模型调用API_KEY"
# BELLDANDY_EMBEDDING_OPENAI_BASE_URL="模型调用地址"
# BELLDANDY_EMBEDDING_MODEL=text-embedding-ada-002

# Kimi K2.5 (Vision Support) 配置示例:
# BELLDANDY_OPENAI_BASE_URL="https://api.moonshot.cn/v1"
# BELLDANDY_OPENAI_API_KEY=sk-xxxxxxxx
# BELLDANDY_OPENAI_MODEL=kimi-k2.5-preview

# Embedding 批处理大小 (默认 2)
# 减小此值可避免 413 Payload Too Large 错误
BELLDANDY_EMBEDDING_BATCH_SIZE=2

# Context Injection（对话开始时自动注入最近记忆摘要）
# 启用后，每次对话开始时会自动从记忆库取最近 N 条记忆注入上下文，让 Agent "记住"近期事件
# 设为 false 可关闭（默认启用）
BELLDANDY_CONTEXT_INJECTION=true

# 注入的记忆条数（默认 5）
BELLDANDY_CONTEXT_INJECTION_LIMIT=5

# 是否允许把 session 类型短期会话记忆也注入上下文（默认 false）
# 建议保持关闭，避免把刚完成的执行步骤再次塞回上下文，引导 Agent 重复执行。
BELLDANDY_CONTEXT_INJECTION_INCLUDE_SESSION=false

# 附带注入最近已完成任务的摘要条数（默认 3）
# 用于提醒 Agent 近期哪些任务已经做过，避免重复重启服务/重复跑命令。
BELLDANDY_CONTEXT_INJECTION_TASK_LIMIT=3

# 自动注入时允许进入上下文的记忆分类（默认 preference,fact,decision,entity）
# 可选值：preference,fact,decision,entity,experience,other
BELLDANDY_CONTEXT_INJECTION_ALLOWED_CATEGORIES=preference,fact,decision,entity,experience

# Task 去重守卫：阻止最近已成功执行过的相同工具动作再次执行（默认 true）
# 可通过工具参数 retry=true / force=true / allowDuplicate=true 显式绕过。
BELLDANDY_TASK_DEDUP_GUARD_ENABLED=false

# Task 去重守卫的时间窗口，单位分钟（默认 20）
BELLDANDY_TASK_DEDUP_WINDOW_MINUTES=2

# 2) 保留重启/切面/方法创建强拦截，但允许重复跑命令：
BELLDANDY_TASK_DEDUP_MODE=graded
BELLDANDY_TASK_DEDUP_POLICY=run_command:off

# Auto-Recall（底层自动语义召回，默认关闭）
# 启用后，在 before_agent_start 阶段会基于用户原始输入自动执行 memory search，并静默注入相关历史记忆
BELLDANDY_AUTO_RECALL_ENABLED=true

# Auto-Recall 每次最多注入的结果条数（默认 3）
BELLDANDY_AUTO_RECALL_LIMIT=3

# Auto-Recall 最低相关性阈值（默认 0.3）
BELLDANDY_AUTO_RECALL_MIN_SCORE=0.35

# 工具结果写回 transcript 的字符上限
# 建议值：12000 字符，足以保留大多数工具结果关键信息，同时避免超长输出在下一轮继续放大 token 成本
BELLDANDY_TOOL_RESULT_TRANSCRIPT_CHAR_LIMIT=12000

# ------ 记忆系统增强（Phase M-Next） ------
# L0 摘要层（默认关闭）
BELLDANDY_MEMORY_SUMMARY_ENABLED=true
# BELLDANDY_MEMORY_SUMMARY_MODEL=gpt-4o-mini
# BELLDANDY_MEMORY_SUMMARY_BASE_URL=
# BELLDANDY_MEMORY_SUMMARY_API_KEY=

# 会话记忆自动提取（默认关闭）
BELLDANDY_MEMORY_EVOLUTION_ENABLED=true
BELLDANDY_MEMORY_EVOLUTION_MIN_MESSAGES=8
# BELLDANDY_MEMORY_EVOLUTION_MODEL=gpt-4o-mini
# BELLDANDY_MEMORY_EVOLUTION_BASE_URL=
# BELLDANDY_MEMORY_EVOLUTION_API_KEY=

# Task Memory：记录任务级执行结果，供 Memory Viewer 的 Tasks 视图使用
# 当前如不准备正式启用 Task 层，请保持 false；开启后会开始写入 tasks 相关数据。
BELLDANDY_TASK_MEMORY_ENABLED=true

# Task Summary：仅对高价值任务生成 LLM 总结；如果只想先沉淀任务结构化数据，可保持 false
# 推荐使用稳定文本模型，例如 moonshot-v1-8k / moonshot-v1-32k
# 不建议使用 embedding 模型（如 text-embedding-v4）或 vision-preview 模型
# BELLDANDY_TASK_SUMMARY_ENABLED=false
# BELLDANDY_TASK_SUMMARY_MODEL=moonshot-v1-8k
# BELLDANDY_TASK_SUMMARY_BASE_URL=
# BELLDANDY_TASK_SUMMARY_API_KEY=

# Task Summary 触发阈值（满足其一即可触发；前提仍需 TASK_MEMORY_ENABLED=true）
# BELLDANDY_TASK_SUMMARY_MIN_DURATION_MS=15000
# BELLDANDY_TASK_SUMMARY_MIN_TOOL_CALLS=2
# BELLDANDY_TASK_SUMMARY_MIN_TOKEN_TOTAL=2000

# 示例 1：只启用 Task Memory，不做任务总结
# BELLDANDY_TASK_MEMORY_ENABLED=true
# BELLDANDY_TASK_SUMMARY_ENABLED=false

# 示例 2：启用 Task Memory，并只对较重任务生成总结
# BELLDANDY_TASK_MEMORY_ENABLED=true
# BELLDANDY_TASK_SUMMARY_ENABLED=true
# BELLDANDY_TASK_SUMMARY_MODEL=moonshot-v1-32k
# BELLDANDY_TASK_SUMMARY_MIN_DURATION_MS=30000
# BELLDANDY_TASK_SUMMARY_MIN_TOOL_CALLS=3
# BELLDANDY_TASK_SUMMARY_MIN_TOKEN_TOTAL=4000

# 源路径聚合检索（默认关闭）
BELLDANDY_MEMORY_DEEP_RETRIEVAL=false

# Task-aware Embedding 前缀（用于 Jina/BGE 等支持 task 参数的模型）
# 查询时在文本前添加 queryPrefix，索引时添加 passagePrefix，可提升检索相关性 5-15%
# BGE 系列示例: BELLDANDY_EMBEDDING_QUERY_PREFIX="query: "  BELLDANDY_EMBEDDING_PASSAGE_PREFIX="passage: "
# Jina 系列示例: BELLDANDY_EMBEDDING_QUERY_PREFIX="retrieval.query: "  BELLDANDY_EMBEDDING_PASSAGE_PREFIX="retrieval.passage: "
# 不设置则不添加前缀（兼容 OpenAI text-embedding 等不需要前缀的模型）
# BELLDANDY_EMBEDDING_QUERY_PREFIX=
# BELLDANDY_EMBEDDING_PASSAGE_PREFIX=

# Reranker 配置
# 硬截断最低分数，低于此分数的检索结果直接丢弃（默认 0.15）
BELLDANDY_RERANKER_MIN_SCORE=0.2
# 长度归一化锚点（字符数），防止长文本靠关键词密度霸榜（默认 500，0 表示不归一化）
BELLDANDY_RERANKER_LENGTH_NORM_ANCHOR=500

# ------ 心跳定时任务 ------
# 启用心跳（Agent 定期检查 HEARTBEAT.md 并主动联系你）
BELLDANDY_HEARTBEAT_ENABLED=true
# 心跳间隔（支持 30m, 1h, 300s 格式）
BELLDANDY_HEARTBEAT_INTERVAL=10m
# 活跃时段（可选，深夜不打扰）
# BELLDANDY_HEARTBEAT_ACTIVE_HOURS=08:00-23:00

# ------ 浏览器自动化 ------
# 启用浏览器中继自动启动 false/true（需配合 Chrome 扩展）
BELLDANDY_BROWSER_RELAY_ENABLED=true
BELLDANDY_RELAY_PORT=28892

# 浏览器域名控制（双模式，类似 web_fetch）
# 白名单：设置后仅允许访问这些域名（不设则不限制）
# BELLDANDY_BROWSER_ALLOWED_DOMAINS=trusted.com,docs.example.com
# 黑名单：禁止访问的域名（永远生效，优先于白名单）
# BELLDANDY_BROWSER_DENIED_DOMAINS=malware.com,phishing-site.net

# ------ 定时任务 (Cron) ------
# 启用 Cron 调度引擎（Agent cron 工具始终可用，此开关仅控制自动调度）
BELLDANDY_CRON_ENABLED=true

# ------ MCP 支持 ------
# 启用 MCP 协议（需同时启用工具系统）
BELLDANDY_MCP_ENABLED=true

# ------ 多 Agent 与子 Agent 编排 ------
# Agent Profile 配置文件位于 ~/.star_sanctuary/agents.json（JSON 格式）
# 不创建此文件时，系统只有一个 default Agent，行为与之前完全一致
# 飞书渠道绑定的 Agent Profile ID（可选，默认使用 default Agent）
# BELLDANDY_FEISHU_AGENT_ID=researcher

# ========================================
# 渠道配置
# ========================================
# Channels 路由引擎（默认关闭，开启后可按规则做 mention gating / agent 路由）
# BELLDANDY_CHANNEL_ROUTER_ENABLED=false
# 路由配置文件（JSON）
# BELLDANDY_CHANNEL_ROUTER_CONFIG_PATH=~/.star_sanctuary/channels-routing.json
# 路由默认 Agent ID（当规则未指定 agentId 时使用）
# BELLDANDY_CHANNEL_ROUTER_DEFAULT_AGENT_ID=default

# ------ Webhook API（外部系统触发）------
# Webhook 配置文件路径（默认 ~/.star_sanctuary/webhooks.json）
# 配置后可通过 HTTP POST 触发 Agent，适用于 CI/CD、监控告警、定时任务等场景
# BELLDANDY_WEBHOOK_CONFIG_PATH=~/.star_sanctuary/webhooks.json
# Webhook 幂等性时间窗口（毫秒，默认 600000 即 10 分钟）
# 通过 X-Idempotency-Key 请求头防止重复执行
# BELLDANDY_WEBHOOK_IDEMPOTENCY_WINDOW_MS=600000
# 使用示例：
# curl -X POST http://127.0.0.1:28889/api/webhook/ci-alert \
#   -H "Authorization: Bearer your-token" \
#   -H "Content-Type: application/json" \
#   -H "X-Idempotency-Key: unique-event-id" \
#   -d '{"text": "CI 构建失败"}'
# 详细文档：docs/webhook.md

# ------ QQ 渠道（可选）------
# BELLDANDY_QQ_APP_ID=xxxxxxxx
# BELLDANDY_QQ_APP_SECRET=xxxxxxxx
# QQ 渠道绑定的 Agent Profile ID（可选，默认使用 default Agent）
# BELLDANDY_QQ_AGENT_ID=default
# 默认开启沙箱环境 (true/false)
# BELLDANDY_QQ_SANDBOX=true

# 子 Agent 最大并发数（默认 3，超出的任务自动排队）
BELLDANDY_SUB_AGENT_MAX_CONCURRENT=3
# 排队队列最大长度（默认 10，队列满时拒绝新任务）
BELLDANDY_SUB_AGENT_MAX_QUEUE_SIZE=10
# 子 Agent 运行超时（毫秒，默认 120000 即 2 分钟）
BELLDANDY_SUB_AGENT_TIMEOUT_MS=300000
# 子 Agent 嵌套委托最大深度（默认 2，防止无限递归）
BELLDANDY_SUB_AGENT_MAX_DEPTH=2

# ------ 模型容灾 (Model Failover) ------
# 备用模型配置文件路径（JSON 格式，默认 ~/.star_sanctuary/models.json）
# 配置后，主模型限流/故障时自动切换到备用模型，在不使用默认路径时才需要配置以下变量。
# BELLDANDY_MODEL_CONFIG_FILE=~/.star_sanctuary/models.json

# ------ 日志系统 ------
# 最低日志级别 (debug/info/warn/error)，可以通过设置 BELLDANDY_LOG_LEVEL=info 来过滤掉所有 debug 级别的浏览器日志。
BELLDANDY_LOG_LEVEL=debug
# 日志目录，默认 ~/.star_sanctuary/logs
BELLDANDY_LOG_DIR=~/.star_sanctuary/logs
# 单文件最大大小，超过则轮转 (如 10MB)
BELLDANDY_LOG_MAX_SIZE=10MB
# 日志保留天数，超过自动清理
BELLDANDY_LOG_RETENTION_DAYS=7
# 是否输出到控制台 / 是否写入文件
BELLDANDY_LOG_CONSOLE=true
BELLDANDY_LOG_FILE=true

# ------ FACET 模组切换配置 ------
# FACET 切换锚点行（switch_facet 工具在 SOUL.md 中查找此字符串作为分界点）
# 锚点行及之前的内容保留，之后的内容会被替换为目标 facet 文件内容
# 注意！如果在 SOUL.md 中有多个相同的锚点行内容，会使用检索到的第一个（最上边）的锚点行
# 默认值：## **警告** FACET 模组 内容切换时，必须在这一行之后执行，不可覆盖替换这一行之前的内容。
# 示例：BELLDANDY_FACET_ANCHOR=<!-- FACET_ANCHOR -->
BELLDANDY_FACET_ANCHOR=<!-- FACET_ANCHOR -->

# ------ System Prompt 注入配置 ------
# 控制是否将 specific workspace files 注入到 System Prompt
# 如果禁用，Agent 将不会被告知这些信息（除非你在自定义 System Prompt 里写了）
# 注入 AGENTS.md (Workspace Guide)
BELLDANDY_INJECT_AGENTS=true
# 注入 SOUL.md (Persona & Guidelines)
BELLDANDY_INJECT_SOUL=true
# 注入 MEMORY.md (Core Memory & Notes)
BELLDANDY_INJECT_MEMORY=false
# System Prompt 最大字符数限制（超过则按优先级自动截断低优先级段落，0 或不设表示不限制）
# 适用于对输入长度有限制的 API 代理（如 aicodewith），建议值 20000~40000
# 换算参考：纯英文约 4 字符 ≈ 1 token，中英混合约 3~4 字符 ≈ 1 token
# 例：20000 字符 ≈ 5000~6600 tokens，40000 字符 ≈ 10000~13000 tokens
BELLDANDY_MAX_SYSTEM_PROMPT_CHARS=0

# 传给模型的最近对话轮数（默认 10）
# 长期记忆已通过向量检索实现，此处仅需保留最近几轮维持对话连贯性
# 使用输入长度受限的 API 代理时建议设为 6~10
BELLDANDY_MAX_HISTORY=10

# ------ 对话压缩（Compaction） ------
# 是否启用上下文自动压缩（默认 true）
# 启用后，当历史消息 token 超过阈值时，自动将旧消息摘要化（三层渐进式压缩）
BELLDANDY_COMPACTION_ENABLED=true
# 当历史消息的估算 token 数超过此阈值时，自动将旧消息摘要化以减少 token 消耗
# 默认 12000（约 12K tokens），设为 0 或不设表示不启用压缩
# 建议anthropic模型设8000，OpenAI模型时设20000
BELLDANDY_COMPACTION_THRESHOLD=12000
# 压缩时保留最近几条消息原文（默认 10）
BELLDANDY_COMPACTION_KEEP_RECENT=6
# ReAct 循环内压缩触发比例（默认 0.75，即上下文窗口使用 75% 时触发循环内压缩）
# 需配合 BELLDANDY_MAX_INPUT_TOKENS 使用
BELLDANDY_COMPACTION_TRIGGER_FRACTION=0.75
# Rolling Summary 超过此 token 数时触发归档压缩（默认 2000）
BELLDANDY_COMPACTION_ARCHIVAL_THRESHOLD=2000
# 摘要专用模型（可选，不设则复用主模型）
BELLDANDY_COMPACTION_MODEL=moonshot-v1-8k
# 摘要专用 API 地址和密钥（可选，不设则复用主模型的 BASE_URL / API_KEY）
# BELLDANDY_COMPACTION_BASE_URL=https://api.openai.com/v1
# BELLDANDY_COMPACTION_API_KEY=sk-xxx

# TTS Configuration
# 启用语音模式（服务端自动将 Agent 回复转为语音，true/false，默认 false）
BELLDANDY_TTS_ENABLED=false
# TTS 提供商: dashscope | edge (free) | openai
BELLDANDY_TTS_PROVIDER="dashscope"
# 语音 ID: DashScope: Cherry/Chelsie | Edge: zh-CN-XiaoxiaoNeural | OpenAI: alloy
BELLDANDY_TTS_VOICE="Chelsie"

# ------ 语音识别 (STT) 配置 ------
# Provider: openai | groq | dashscope (默认 openai)
BELLDANDY_STT_PROVIDER=dashscope
# 语言提示 (默认 zh)
BELLDANDY_STT_LANGUAGE=zh

# Groq STT (如果不使用 OpenAI)
# BELLDANDY_STT_GROQ_API_KEY=gsk_xxx
# BELLDANDY_STT_GROQ_BASE_URL=https://api.groq.com/openai/v1

# ========================================
# 身份上下文系统配置（可选）
# ========================================
# 智能注入阈值：房间成员数 ≤ 此值时，在 System Prompt 中注入完整成员列表
# 房间成员数 > 此值时，仅注入统计信息，Agent 需调用工具查询详细信息
# 默认值：10（推荐值，平衡体验与 token 消耗）
# 调优建议：
# - 设为 5：更激进的 token 节省，但小型房间也需要调用工具
# - 设为 15：更好的用户体验，但中型房间 token 消耗增加
BELLDANDY_ROOM_INJECT_THRESHOLD=10

# 房间成员列表缓存有效期（毫秒）
# 默认值：300000（5分钟）
# 说明：在同一会话中多次查询成员列表时，使用缓存可大幅节省 token
# 调优建议：
# - 成员变动频繁的场景：设为 60000（1分钟）
# - 成员变动不频繁的场景：设为 600000（10分钟）
BELLDANDY_ROOM_MEMBERS_CACHE_TTL=600000

{
  "name": "@belldandy/core",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./cron": {
      "types": "./dist/cron/index.d.ts",
      "import": "./dist/cron/index.js",
      "default": "./dist/cron/index.js"
    }
  },
  "bin": {
    "belldandy": "./dist/bin/bdd.js",
    "bdd": "./dist/bin/bdd.js"
  },
  "scripts": {
    "prebuild": "node ../../scripts/generate-version.mjs",
    "build": "tsc -b"
  },
  "dependencies": {
    "@belldandy/agent": "workspace:*",
    "@belldandy/browser": "workspace:*",
    "@belldandy/channels": "workspace:*",
    "@belldandy/mcp": "workspace:*",
    "@belldandy/memory": "workspace:*",
    "@belldandy/plugins": "workspace:*",
    "@belldandy/protocol": "workspace:*",
    "@belldandy/skills": "workspace:*",
    "@star-sanctuary/distribution": "workspace:*",
    "citty": "^0.1.6",
    "@clack/prompts": "^0.10.0",
    "express": "^5.1.0",
    "open": "^11.0.0",
    "picocolors": "^1.1.1",
    "ws": "^8.18.3"
  }
}

BELLDANDY_AGENT_PROVIDER=openai
#用中转代理调用claude-opus等模型时启用下方这条设置,Anthropic官方不需启用
# BELLDANDY_AGENT_PROTOCOL=anthropic

# 流式输出（默认 true）
BELLDANDY_OPENAI_STREAM=true

# OpenAI 线路协议：chat_completions（默认）| responses
# 使用 aicodewith 的 gpt-5.3-codex 时通常需要设置为 responses
BELLDANDY_OPENAI_WIRE_API=chat_completions


# MinMax-M2.5配置：
BELLDANDY_OPENAI_API_KEY=
BELLDANDY_OPENAI_BASE_URL="https://api.minimaxi.com/v1"
BELLDANDY_OPENAI_MODEL="MiniMax-M2.7-highspeed"

# System Prompt 最大字符数限制（超过则按优先级自动截断低优先级段落，0 或不设表示不限制）
# 适用于对输入长度有限制的 API 代理（如 aicodewith），建议值 20000~40000
# 换算参考：纯英文约 4 字符 ≈ 1 token，中英混合约 3~4 字符 ≈ 1 token
# 例：20000 字符 ≈ 5000~6600 tokens，40000 字符 ≈ 10000~13000 tokens
# BELLDANDY_MAX_SYSTEM_PROMPT_CHARS=6000

# ------ 记忆与向量检索 ------
# 启用向量搜索（需要 Embedding 模型）
# 模型会自动下载并保存到 ~/.belldandy/models 文件夹中
BELLDANDY_EMBEDDING_ENABLED="false"
# Embedding 提供商选择: openai | local (默认是 openai)
# BELLDANDY_EMBEDDING_PROVIDER=openai
# 本地模型名称 (仅当 provider=local 时生效)
# BELLDANDY_EMBEDDING_PROVIDER=local
# BELLDANDY_EMBEDDING_PROVIDER=openai
BELLDANDY_EMBEDDING_PROVIDER=openai
# BELLDANDY_LOCAL_EMBEDDING_MODEL=BAAI/bge-m3
# 如果您的 Embedding 服务使用不同的 Key/BaseURL，请在此配置；否则默认使用上方的通用配置
BELLDANDY_EMBEDDING_OPENAI_API_KEY=
BELLDANDY_EMBEDDING_OPENAI_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"
BELLDANDY_EMBEDDING_MODEL="text-embedding-v4"

# ------ 记忆系统增强（Phase M-Next） ------
# L0 摘要层（默认关闭）
BELLDANDY_MEMORY_SUMMARY_ENABLED=true
BELLDANDY_MEMORY_SUMMARY_MODEL="qwen3.6-flash"
BELLDANDY_MEMORY_SUMMARY_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"
BELLDANDY_MEMORY_SUMMARY_API_KEY=

# 会话记忆自动提取（默认关闭，高级模型可用qwen3-max）
BELLDANDY_MEMORY_EVOLUTION_ENABLED=true
BELLDANDY_MEMORY_EVOLUTION_MIN_MESSAGES=8
BELLDANDY_MEMORY_EVOLUTION_MODEL="qwen3.6-flash"
BELLDANDY_MEMORY_EVOLUTION_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"
BELLDANDY_MEMORY_EVOLUTION_API_KEY=

# 摘要专用模型（可选，不设则复用主模型）
BELLDANDY_COMPACTION_MODEL="qwen3.6-flash"
# 摘要专用 API 地址和密钥（可选，不设则复用主模型的 BASE_URL / API_KEY）
BELLDANDY_COMPACTION_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"
BELLDANDY_COMPACTION_API_KEY=

# 源路径聚合检索（默认关闭）
BELLDANDY_MEMORY_DEEP_RETRIEVAL=true

# 飞书相关配置
BELLDANDY_FEISHU_APP_ID="your_app_id_here"
BELLDANDY_FEISHU_APP_SECRET=your_app_secret_here

BELLDANDY_HEARTBEAT_INTERVAL="600s"

# ------ QQ 渠道（可选）------
BELLDANDY_QQ_APP_ID="your_app_id_here"
BELLDANDY_QQ_APP_SECRET=your_app_secret_here
# QQ 渠道绑定的 Agent Profile ID（可选，默认使用 default Agent）
BELLDANDY_QQ_AGENT_ID="default"
# 默认开启沙箱环境 (true/false)
BELLDANDY_QQ_SANDBOX="true"

# ------ Discord 渠道（可选）------
# 申请流程：https://discord.com/developers/applications
# 1. 创建 Application → Bot 页面 → Reset Token 获取 Bot Token
# 2. 开启 MESSAGE CONTENT INTENT（必须）
# 3. OAuth2 → URL Generator → bot → 勾选权限 → 邀请到服务器
BELLDANDY_DISCORD_ENABLED="false"
BELLDANDY_DISCORD_BOT_TOKEN=your_token_here
# BELLDANDY_DISCORD_DEFAULT_CHANNEL_ID=


# 方案：视频上传和聊天请求都用同一套 Moonshot 直连 URL + Key。
#   - 有视频理解能力的模型（如 Kimi K2.5）→ 能看懂 ms:// 引用的视频
#   - 没有视频理解能力的模型 → 看不懂，但也不会崩溃（最多忽略或报不支持）
# 这样的话，你只需要把 .env.local 里的 BELLDANDY_OPENAI_BASE_URL 和 BELLDANDY_OPENAI_API_KEY 改成 Moonshot 直连地址和 Key，不再走 aiping.cn 代理。之前加的 BELLDANDY_VIDEO_FILE_API_URL / BELLDANDY_VIDEO_FILE_API_KEY 就不需要了（或者留着作为备用，不设就不生效）。
# BELLDANDY_VIDEO_FILE_API_URL=https://api.moonshot.cn/v1
# BELLDANDY_VIDEO_FILE_API_KEY=

# Aliyun DashScope TTS
# 请在此处填入你的 API Key
DASHSCOPE_API_KEY=

# Token 消耗上传到 office.goddess.ai（默认关闭）
# 作用：把每次新增的 token 消耗（delta）上报给 office 的 /api/internal/token-usage
# 使用步骤（通俗版）：
# 1) 先把 ENABLED 改成 true
# 2) URL 填 office 后端地址（通常是 https://api.goddess-ai.top/api/internal/token-usage）
# 3) APIKEY 填“该用户在 office.goddess.ai 里生成的 API Key 明文（gro_...）”
# 4) Belldandy 会自动带请求头：Authorization: Bearer <APIKEY>
# 5) office 后端会用这个 API Key 反查归属用户并累计到该用户账号
BELLDANDY_TOKEN_USAGE_UPLOAD_ENABLED=false
# 接收端接口（office 内部路由）
BELLDANDY_TOKEN_USAGE_UPLOAD_URL=https://api.goddess-ai.top/api/internal/token-usage
# 上传鉴权 API Key（推荐：每用户独立 key，便于单独吊销）
BELLDANDY_TOKEN_USAGE_UPLOAD_APIKEY=your_api_key_here
# 上传超时（毫秒，默认 3000）
BELLDANDY_TOKEN_USAGE_UPLOAD_TIMEOUT_MS=15000

# community 上传是否启用“严格 UUID 模式”（默认 false）
# - true：若未从根目录 IDENTITY.md 解析到“主人UUID”，community 上报在接收端 strict uuid 校验开启时可能失败
# - false：即使缺少主人 UUID 也继续上传（请求体不带 userUuid）
# 建议：接收端开启 strict uuid 校验时设为 true，并确保根目录 IDENTITY.md 含“主人UUID”字段
BELLDANDY_TOKEN_USAGE_STRICT_UUID=false
# IDENTITY.md 示例：**主人UUID**: 123e4567-e89b-12d3-a456-426614174000

# 模型调用设置
BELLDANDY_OPENAI_MAX_RETRIES=1
BELLDANDY_OPENAI_RETRY_BACKOFF_MS=300
BELLDANDY_PRIMARY_WARMUP_ENABLED=true
BELLDANDY_PRIMARY_WARMUP_TIMEOUT_MS=8000
BELLDANDY_PRIMARY_WARMUP_COOLDOWN_MS=60000

# Task Memory：记录任务级执行结果，供 Memory Viewer 的 Tasks 视图使用
# 当前如不准备正式启用 Task 层，请保持 false；开启后会开始写入 tasks 相关数据。
BELLDANDY_TASK_MEMORY_ENABLED=true

# Task Summary：仅对高价值任务生成 LLM 总结；如果只想先沉淀任务结构化数据，可保持 false
# 推荐使用稳定文本模型，例如 qwen3.6-flash
# 不建议使用 embedding 模型（如 text-embedding-v4）或 vision-preview 模型
BELLDANDY_TASK_SUMMARY_ENABLED=true
BELLDANDY_TASK_SUMMARY_MODEL="qwen3.6-flash"
BELLDANDY_TASK_SUMMARY_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"
BELLDANDY_TASK_SUMMARY_API_KEY=

# Task Summary 触发阈值（满足其一即可触发；前提仍需 TASK_MEMORY_ENABLED=true）
BELLDANDY_TASK_SUMMARY_MIN_DURATION_MS=30000
BELLDANDY_TASK_SUMMARY_MIN_TOOL_CALLS=3
BELLDANDY_TASK_SUMMARY_MIN_TOKEN_TOTAL=4000

# 第五阶段：Method / Skill 半自动沉淀（默认开启）
# 前提：需要先开启 TASK_MEMORY，否则不会记录 task，自然也不会生成候选。
# 当前自动生成只会写入 experience_candidates 候选层，不会自动发布到正式 methods/ 或用户 skills/。
# 当前自动生成走规则化提炼，不直接依赖 TASK_SUMMARY_MODEL。
# TASK_SUMMARY 只是在开启后补强 task 的 summary/reflection/outcome，从而间接提升候选质量。
BELLDANDY_EXPERIENCE_AUTO_PROMOTION_ENABLED=true

# 自动生成 method 候选（默认开启）
BELLDANDY_EXPERIENCE_AUTO_METHOD_ENABLED=true

# 自动生成 skill 候选草稿（默认开启）
BELLDANDY_EXPERIENCE_AUTO_SKILL_ENABLED=true

# Method / Skill 生成是否需要用户确认（默认 false）
# 影响 task detail 里的“生成 method candidate / 生成 skill candidate”等入口
BELLDANDY_METHOD_GENERATION_CONFIRM_REQUIRED=false
BELLDANDY_SKILL_GENERATION_CONFIRM_REQUIRED=false

# Method / Skill 发布是否需要用户确认（默认 false；如需更保守可手动改为 true）
# 影响 candidate panel 里的“接受并发布”等入口
BELLDANDY_METHOD_PUBLISH_CONFIRM_REQUIRED=true
BELLDANDY_SKILL_PUBLISH_CONFIRM_REQUIRED=true

# 示例 3：只自动沉淀 method，关闭 skill 自动草稿
# BELLDANDY_TASK_MEMORY_ENABLED=true
# BELLDANDY_EXPERIENCE_AUTO_PROMOTION_ENABLED=true
# BELLDANDY_EXPERIENCE_AUTO_METHOD_ENABLED=true
# BELLDANDY_EXPERIENCE_AUTO_SKILL_ENABLED=false

# 工具开关确认密码（仅在 BELLDANDY_AGENT_TOOL_CONTROL_MODE=confirm 时生效）
# - 留空：沿用“批准工具设置变更 <requestId>”确认口令
# - 已设置：用户改为输入这里配置的确认口令；系统不会回显该口令
BELLDANDY_AGENT_TOOL_CONTROL_CONFIRM_PASSWORD=your_password_here

BELLDANDY_HEARTBEAT_ENABLED="true"

BELLDANDY_HEARTBEAT_ACTIVE_HOURS=""

BELLDANDY_BROWSER_RELAY_ENABLED="true"

BELLDANDY_RELAY_PORT="28892"

BELLDANDY_MCP_ENABLED="true"

BELLDANDY_CRON_ENABLED="true"

BELLDANDY_TOOLS_ENABLED="true"

BELLDANDY_AGENT_BRIDGE_ENABLED="true"

BELLDANDY_AGENT_TOOL_CONTROL_MODE="confirm"

BELLDANDY_TTS_ENABLED="false"

BELLDANDY_TTS_PROVIDER="dashscope"

BELLDANDY_TTS_VOICE="Chelsie"

# 如需为 TTS 单独配置 OpenAI endpoint，可额外设置以下两项；未设置时会回退到全局 BELLDANDY_OPENAI_*
# BELLDANDY_TTS_OPENAI_BASE_URL=
# BELLDANDY_TTS_OPENAI_API_KEY=
# 注意：DASHSCOPE_API_KEY 只用于 DashScope provider，不要填到 BELLDANDY_TTS_OPENAI_API_KEY

BELLDANDY_FACET_ANCHOR="<!-- FACET_ANCHOR -->"

BELLDANDY_INJECT_AGENTS="true"

BELLDANDY_INJECT_SOUL="true"

BELLDANDY_INJECT_MEMORY="false"

BELLDANDY_MAX_SYSTEM_PROMPT_CHARS="0"

BELLDANDY_MAX_HISTORY="10"

BELLDANDY_PROMPT_SNAPSHOT_EMAIL_THREAD_MAX_RUNS="10"

BELLDANDY_COMMUNITY_API_ENABLED="true"

BELLDANDY_COMMUNITY_API_TOKEN="your_token_here"

BELLDANDY_FEISHU_AGENT_ID=""

BELLDANDY_DISCORD_DEFAULT_CHANNEL_ID=""

BELLDANDY_CONVERSATION_ALLOWED_KINDS="main,subtask,goal"

BELLDANDY_MODEL_PREFERRED_PROVIDERS=""

BELLDANDY_EXTERNAL_OUTBOUND_REQUIRE_CONFIRMATION="true"


BELLDANDY_ASSISTANT_MODE_ENABLED="true"
BELLDANDY_ASSISTANT_EXTERNAL_DELIVERY_PREFERENCE="feishu,qq,community,discord"

# Dream 自动整理
# heartbeat / cron 这里只提供触发检查机会，是否真正运行仍由 dream 内部 gate 判定
BELLDANDY_DREAM_AUTO_HEARTBEAT_ENABLED="true"
BELLDANDY_DREAM_AUTO_CRON_ENABLED="true"

# Dream -> Obsidian 私有镜像
BELLDANDY_DREAM_OBSIDIAN_ENABLED="true"
BELLDANDY_DREAM_OBSIDIAN_VAULT_PATH=""
BELLDANDY_DREAM_OBSIDIAN_ROOT_DIR="Star Sanctuary"

# Commons -> Obsidian 公共租界
BELLDANDY_COMMONS_OBSIDIAN_ENABLED="true"
BELLDANDY_COMMONS_OBSIDIAN_VAULT_PATH=""
BELLDANDY_COMMONS_OBSIDIAN_ROOT_DIR="Star Sanctuary"

# ========================================
# QQ 邮箱（SMTP 发信 + IMAP 收信）
# 说明：
# 1. 这里填写的是 QQ 邮箱“授权码”，不是 QQ 登录密码
# 2. 当前只差 SMTP/IMAP 的 PASS 两行，请手动填入同一份授权码
# 3. 修改后保存，Gateway 应会自动检测 .env.local 变更并重启
# ========================================

BELLDANDY_EMAIL_DEFAULT_PROVIDER="smtp"
BELLDANDY_EMAIL_OUTBOUND_REQUIRE_CONFIRMATION="true"

BELLDANDY_EMAIL_SMTP_ENABLED="true"
BELLDANDY_EMAIL_SMTP_ACCOUNT_ID="default"
BELLDANDY_EMAIL_SMTP_HOST="smtp.qq.com"
BELLDANDY_EMAIL_SMTP_PORT="465"
BELLDANDY_EMAIL_SMTP_SECURE="true"
BELLDANDY_EMAIL_SMTP_USER="your_mail_user_here"
BELLDANDY_EMAIL_SMTP_PASS="your_password_here"
BELLDANDY_EMAIL_SMTP_FROM_ADDRESS="noreply@example.com"
BELLDANDY_EMAIL_SMTP_FROM_NAME="Example Sender"

BELLDANDY_EMAIL_INBOUND_AGENT_ID="default"
BELLDANDY_EMAIL_IMAP_ENABLED="true"
BELLDANDY_EMAIL_IMAP_ACCOUNT_ID="default"
BELLDANDY_EMAIL_IMAP_HOST="imap.qq.com"
BELLDANDY_EMAIL_IMAP_PORT="993"
BELLDANDY_EMAIL_IMAP_SECURE="true"
BELLDANDY_EMAIL_IMAP_USER="your_mail_user_here"
BELLDANDY_EMAIL_IMAP_PASS="your_password_here"
BELLDANDY_EMAIL_IMAP_MAILBOX="INBOX"
BELLDANDY_EMAIL_IMAP_POLL_INTERVAL_MS="120000"
BELLDANDY_EMAIL_IMAP_CONNECT_TIMEOUT_MS="15000"
BELLDANDY_EMAIL_IMAP_SOCKET_TIMEOUT_MS="60000"
BELLDANDY_EMAIL_IMAP_BOOTSTRAP_MODE="latest"
BELLDANDY_EMAIL_IMAP_RECENT_WINDOW_LIMIT="50"

BELLDANDY_TTS_OPENAI_BASE_URL=""

BELLDANDY_TTS_OPENAI_API_KEY="your_api_key_here"


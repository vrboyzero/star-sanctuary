# ============================================
# Belldandy 环境变量配置模板
# ============================================
# 使用说明：
# 1. 本地开发：复制为 .env.local（Git 忽略）
# 2. Docker 部署：复制为 .env
# 3. 填写必需的配置项（标记为 REQUIRED）

# ========================================
# Docker 镜像配置（仅 Docker 部署需要）
# ========================================
BELLDANDY_IMAGE=belldandy:local

# ========================================
# 网络配置
# ========================================
# 绑定地址（127.0.0.1=仅本机，0.0.0.0=允许局域网访问）
BELLDANDY_HOST=127.0.0.1

# Gateway 端口
BELLDANDY_PORT=28889
BELLDANDY_GATEWAY_PORT=28889  # Docker Compose 使用此变量

# ========================================
# 认证配置（REQUIRED）
# ========================================
# 认证模式: none / token / password（默认 none）
# 注意：即使是 none，新设备连接也需要 Pairing 配对
# 警告：使用 0.0.0.0 时禁止使用 none 模式
BELLDANDY_AUTH_MODE=token

# Token 认证（当 AUTH_MODE=token 时必填）
# 生成方法: openssl rand -hex 32
BELLDANDY_AUTH_TOKEN=your-secure-token-here

# 密码认证（当 AUTH_MODE=password 时必填）
# BELLDANDY_AUTH_PASSWORD=your-secure-password-here

# WebSocket Origin 白名单（逗号分隔，防 CSWSH 攻击）
# 作用：限制哪些网页/客户端可以连接到 Belldandy Gateway
# 默认行为：若不设置，本地开发环境（HOST=127.0.0.1）自动允许 localhost/127.0.0.1
# 配置建议：
# - 纯本地使用（命令行）：不需要配置
# - 本地 Web 开发：BELLDANDY_ALLOWED_ORIGINS=http://localhost:5173
# - 公网部署/生产环境：BELLDANDY_ALLOWED_ORIGINS=https://console.belldandy.ai
# BELLDANDY_ALLOWED_ORIGINS=http://localhost:3000,https://app.example.com

# ========================================
# Agent 配置（REQUIRED）
# ========================================
# Agent 提供商: mock / openai（默认 mock）
BELLDANDY_AGENT_PROVIDER=openai

# OpenAI 兼容 API 配置
# 支持 OpenAI、Gemini、DeepSeek、Ollama 等兼容服务
BELLDANDY_OPENAI_BASE_URL=https://api.openai.com/v1
BELLDANDY_OPENAI_API_KEY=sk-your-api-key-here
BELLDANDY_OPENAI_MODEL=gpt-4o

# Kimi K2.5 (Vision Support) 配置示例:
# BELLDANDY_OPENAI_BASE_URL=https://api.moonshot.cn/v1
# BELLDANDY_OPENAI_API_KEY=sk-xxxxxxxx
# BELLDANDY_OPENAI_MODEL=kimi-k2.5-preview

# 流式输出（默认 true）
# BELLDANDY_OPENAI_STREAM=true

# 额外的系统提示词（追加到 workspace prompt 之后）
# BELLDANDY_OPENAI_SYSTEM_PROMPT=

# 单次模型调用超时（毫秒，默认 120000 即 2 分钟，最小 5000）
# BELLDANDY_AGENT_TIMEOUT_MS=120000

# API 协议：openai | anthropic（默认自动检测）
# 如果 BELLDANDY_OPENAI_BASE_URL 包含 anthropic.com，prompt caching 会自动启用
# 使用 Anthropic 原生协议可启用 Prompt Caching，显著降低 token 消耗和限流风险
# BELLDANDY_AGENT_PROTOCOL=anthropic

# ========================================
# 视频文件上传（Video File Upload）
# ========================================
# 当聊天代理（OPENAI_BASE_URL）不支持 Moonshot /files 端点时，
# 设置此项让视频上传走 Moonshot 直连 API。
# 仅设置 URL 时，API Key 回退到 BELLDANDY_OPENAI_API_KEY。
# BELLDANDY_VIDEO_FILE_API_URL=https://api.moonshot.cn/v1
# BELLDANDY_VIDEO_FILE_API_KEY=sk-xxx

# ========================================
# 模型容灾 (Model Failover)
# ========================================
# 备用模型配置文件路径（JSON 格式，默认 ~/.belldandy/models.json）
# 配置后，主模型限流/故障时自动切换到备用模型，在不使用默认路径时才需要配置以下变量。
# 格式参考: { "fallbacks": [{ "id": "backup", "baseUrl": "https://api.deepseek.com", "apiKey": "sk-xxx", "model": "deepseek-chat" }] }
# BELLDANDY_MODEL_CONFIG_FILE=~/.belldandy/models.json

# ========================================
# Embedding 配置（向量检索）
# ========================================
# 启用向量检索（需配置 Embedding 模型）
BELLDANDY_EMBEDDING_ENABLED=false

# Embedding 提供商选择: openai | local（默认 openai）
BELLDANDY_EMBEDDING_PROVIDER=openai

# OpenAI Embedding 模型
BELLDANDY_EMBEDDING_MODEL=text-embedding-3-small

# 本地 Embedding 模型名称（仅当 provider=local 时生效）
# 默认使用 "BAAI/bge-m3"，这是一款性能非常强大的多语言模型
# 模型会自动下载并保存到工作区目录下的 .belldandy/models 文件夹中
# BELLDANDY_LOCAL_EMBEDDING_MODEL=BAAI/bge-base-en-v1.5

# Embedding API 配置（留空则使用 BELLDANDY_OPENAI_* 配置）
# BELLDANDY_EMBEDDING_OPENAI_API_KEY=
# BELLDANDY_EMBEDDING_OPENAI_BASE_URL=

# Embedding 批处理大小（默认 2）
# 减小此值可避免 413 Payload Too Large 错误
BELLDANDY_EMBEDDING_BATCH_SIZE=2

# Context Injection（对话开始时自动注入最近记忆摘要）
# 启用后，每次对话开始时会自动从记忆库取最近 N 条记忆注入上下文，让 Agent "记住"近期事件
# 设为 false 可关闭（默认启用）
# BELLDANDY_CONTEXT_INJECTION=true

# 注入的记忆条数（默认 5）
# BELLDANDY_CONTEXT_INJECTION_LIMIT=5

# ========================================
# 记忆系统增强（Phase M-Next）
# ========================================
# L0 摘要层：索引后自动为长 chunk 生成 LLM 摘要，memory_search 默认返回摘要以节省 token
# BELLDANDY_MEMORY_SUMMARY_ENABLED=false

# 摘要生成用的模型（建议小模型以降低成本，默认继承主模型）
# BELLDANDY_MEMORY_SUMMARY_MODEL=gpt-4o-mini

# 摘要 API 地址和密钥（可选，默认继承主模型配置）
# BELLDANDY_MEMORY_SUMMARY_BASE_URL=
# BELLDANDY_MEMORY_SUMMARY_API_KEY=

# 会话记忆自动提取：会话结束后自动分析对话，提取用户偏好和经验教训写入每日记忆文件
# BELLDANDY_MEMORY_EVOLUTION_ENABLED=false

# 触发提取的最少消息数（默认 4，过短的对话不提取）
# BELLDANDY_MEMORY_EVOLUTION_MIN_MESSAGES=4

# 提取用的模型（可选，默认继承主模型）
# BELLDANDY_MEMORY_EVOLUTION_MODEL=gpt-4o-mini

# 提取 API 地址和密钥（可选，默认继承主模型配置）
# BELLDANDY_MEMORY_EVOLUTION_BASE_URL=
# BELLDANDY_MEMORY_EVOLUTION_API_KEY=

# 源路径聚合检索：搜索时对高频命中的文件自动拉取上下文 chunk，提升长文档检索连贯性
# BELLDANDY_MEMORY_DEEP_RETRIEVAL=false

# Task-aware Embedding 前缀（用于 Jina/BGE 等支持 task 参数的模型）
# 查询时在文本前添加 queryPrefix，索引时添加 passagePrefix，可提升检索相关性 5-15%
# BGE 系列示例: BELLDANDY_EMBEDDING_QUERY_PREFIX="query: "  BELLDANDY_EMBEDDING_PASSAGE_PREFIX="passage: "
# Jina 系列示例: BELLDANDY_EMBEDDING_QUERY_PREFIX="retrieval.query: "  BELLDANDY_EMBEDDING_PASSAGE_PREFIX="retrieval.passage: "
# 不设置则不添加前缀（兼容 OpenAI text-embedding 等不需要前缀的模型）
# BELLDANDY_EMBEDDING_QUERY_PREFIX=
# BELLDANDY_EMBEDDING_PASSAGE_PREFIX=

# Reranker 配置
# 硬截断最低分数，低于此分数的检索结果直接丢弃（默认 0.15）
# BELLDANDY_RERANKER_MIN_SCORE=0.15
# 长度归一化锚点（字符数），防止长文本靠关键词密度霸榜（默认 500，0 表示不归一化）
# BELLDANDY_RERANKER_LENGTH_NORM_ANCHOR=500

# ========================================
# 功能开关
# ========================================
# 启用工具调用（ReAct 循环）
BELLDANDY_TOOLS_ENABLED=true

# 工具分组加载（默认 all 加载全部，逗号分隔可选组）
# 可选组：browser（浏览器自动化）, multimedia（摄像头/图片生成/TTS）, methodology（方法论SOP）, system（日志/定时任务/重启/模组切换）
# core 组（file/fetch/memory/apply_patch）始终加载，无需指定
# 使用中转代理时建议只加载需要的组以减少 token 消耗
# 示例：BELLDANDY_TOOL_GROUPS=core（只加载核心工具）
# 示例：BELLDANDY_TOOL_GROUPS=browser,system（加载核心+浏览器+系统工具）
# BELLDANDY_TOOL_GROUPS=all

# 最大输入 token 数限制（超过时自动裁剪历史消息，0 或不设表示不限制）
# 使用有输入长度限制的中转代理时建议设置，如 BELLDANDY_MAX_INPUT_TOKENS=20000
# BELLDANDY_MAX_INPUT_TOKENS=0

# 启用记忆系统
BELLDANDY_MEMORY_ENABLED=true

# 记忆数据库路径
# BELLDANDY_MEMORY_DB=~/.belldandy/memory.db

# 启用 MCP 协议支持
BELLDANDY_MCP_ENABLED=false

# 启用浏览器自动化
BELLDANDY_BROWSER_RELAY_ENABLED=false

# 浏览器 Relay 端口
# BELLDANDY_RELAY_PORT=28892

# 启用定时任务
BELLDANDY_CRON_ENABLED=false

# 启用心跳检查
BELLDANDY_HEARTBEAT_ENABLED=false

# 心跳检查间隔（支持 30m, 1h, 300s 格式）
# BELLDANDY_HEARTBEAT_INTERVAL=30m

# 心跳活跃时间窗口（例如 08:00-23:00）
# BELLDANDY_HEARTBEAT_ACTIVE_HOURS=

# ========================================
# 数据持久化路径
# ========================================
# 状态目录（配置、会话、记忆数据库；同时是 file_read/file_write/file_delete 的工作区根目录）
BELLDANDY_STATE_DIR=~/.belldandy

# 工作区目录（文件工具访问范围，Docker 部署使用）
BELLDANDY_WORKSPACE_DIR=./workspace

# 额外允许 Agent 读写的根目录（逗号分隔，如其他盘符下的目录）
# 不设则仅限上面状态目录
# BELLDANDY_EXTRA_WORKSPACE_ROOTS=E:\tools,D:\projects

# WebChat 静态文件路径（通常无需修改）
# BELLDANDY_WEB_ROOT=apps/web/public

# ========================================
# 日志配置
# ========================================
# 最低日志级别 (debug/info/warn/error)，可以通过设置 BELLDANDY_LOG_LEVEL=info 来过滤掉所有 debug 级别的浏览器日志。
BELLDANDY_LOG_LEVEL=info
# 是否输出到控制台 / 是否写入文件
BELLDANDY_LOG_CONSOLE=true
BELLDANDY_LOG_FILE=true

# 日志目录
BELLDANDY_LOG_DIR=~/.belldandy/logs

# 单个日志文件最大大小（触发轮转）
BELLDANDY_LOG_MAX_SIZE=10MB

# 日志保留天数（自动清理）
BELLDANDY_LOG_RETENTION_DAYS=7

# ========================================
# 工具与安全配置
# ========================================
# 危险工具开关（run_command）
# BELLDANDY_DANGEROUS_TOOLS_ENABLED=false

# 工具策略配置文件（覆盖默认工具策略）
# BELLDANDY_TOOLS_POLICY_FILE=~/.belldandy/tools-policy.json

# ========================================
# 对话压缩（Context Compaction）
# ========================================
# 是否启用上下文自动压缩（默认 true）
# 启用后，当历史消息 token 超过阈值时，自动将旧消息摘要化（三层渐进式压缩）
# BELLDANDY_COMPACTION_ENABLED=true

# 当历史消息的估算 token 数超过此阈值时，自动将旧消息摘要化以减少 token 消耗
# 默认 12000（约 12K tokens），设为 0 或不设表示不启用压缩
# 建议 Anthropic 模型设 8000，OpenAI 模型时设 20000
BELLDANDY_COMPACTION_THRESHOLD=20000

# 压缩时保留最近几条消息原文（默认 10）
BELLDANDY_COMPACTION_KEEP_RECENT=10

# ReAct 循环内压缩触发比例（默认 0.75，即上下文窗口使用 75% 时触发循环内压缩）
# 需配合 BELLDANDY_MAX_INPUT_TOKENS 使用
# BELLDANDY_COMPACTION_TRIGGER_FRACTION=0.75

# Rolling Summary 超过此 token 数时触发归档压缩（默认 2000）
# 归档压缩会将滚动摘要进一步浓缩为超简洁版本
# BELLDANDY_COMPACTION_ARCHIVAL_THRESHOLD=2000

# 摘要专用模型（可选，不设则复用主模型）
# 建议使用便宜/快速的模型（如 gpt-4o-mini）以降低成本
# BELLDANDY_COMPACTION_MODEL=gpt-4o-mini

# 摘要专用 API 地址和密钥（可选，不设则复用主模型的 BASE_URL / API_KEY）
# 当摘要模型与主模型不在同一服务商时需要配置
# BELLDANDY_COMPACTION_BASE_URL=https://api.openai.com/v1
# BELLDANDY_COMPACTION_API_KEY=sk-xxx

# ========================================
# TTS（语音合成）配置
# ========================================
# 启用语音模式（服务端自动将 Agent 回复转为语音，默认 false）
# BELLDANDY_TTS_ENABLED=false

# TTS 提供商: dashscope | edge (free) | openai
BELLDANDY_TTS_PROVIDER=edge

# 语音 ID: DashScope: Cherry | Edge: zh-CN-XiaoxiaoNeural | OpenAI: alloy
BELLDANDY_TTS_VOICE=zh-CN-XiaoxiaoNeural

# Aliyun DashScope TTS（可选）
# 获取 Key: https://help.aliyun.com/zh/model-studio/get-api-key
# DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ========================================
# 渠道配置
# ========================================
# 飞书渠道配置
# BELLDANDY_FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
# BELLDANDY_FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 飞书渠道绑定的 Agent Profile ID（可选，默认使用 default Agent）
# 需先在 ~/.belldandy/agents.json 中定义对应 profile
# BELLDANDY_FEISHU_AGENT_ID=researcher

# QQ 渠道配置
# BELLDANDY_QQ_APP_ID=xxxxxxxx
# BELLDANDY_QQ_APP_SECRET=xxxxxxxx
# BELLDANDY_QQ_APP_TOKEN=xxxxxxxx

# QQ 渠道绑定的 Agent Profile ID（可选，默认使用 default Agent）
# BELLDANDY_QQ_AGENT_ID=default

# 默认开启沙箱环境（true/false）
# BELLDANDY_QQ_SANDBOX=true

# ----------------------------------------
# Discord 渠道配置
# ----------------------------------------
# 申请流程：https://discord.com/developers/applications
# 1. 创建 Application → 进入 Bot 页面 → Reset Token 获取 Bot Token
# 2. 开启 Privileged Gateway Intents：MESSAGE CONTENT INTENT（必须）
# 3. OAuth2 → URL Generator → Scopes: bot → 勾选 Send Messages / Read Message History 等权限 → 邀请到服务器
# 启用 Discord 渠道
# BELLDANDY_DISCORD_ENABLED=false

# Bot Token（在 Discord Developer Portal → Bot 页面获取）
# BELLDANDY_DISCORD_BOT_TOKEN=your-discord-bot-token-here

# 默认主动消息发送目标频道 ID（右键频道 → 复制频道 ID，需开启开发者模式）
# 用于心跳提醒、定时任务等主动推送场景；不设则使用最后活跃频道
# BELLDANDY_DISCORD_DEFAULT_CHANNEL_ID=

# ========================================
# 多 Agent 配置
# ========================================
# Agent 配置文件路径（JSON 格式，默认 ~/.belldandy/agents.json）
# 配置多个 Agent 实例，每个可使用不同模型和工具白名单
# 格式参考:
# {
#   "agents": [
#     {
#       "id": "coder",
#       "displayName": "编程助手",
#       "model": "primary",
#       "toolWhitelist": ["file_read", "file_write", "run_command"]
#     },
#     {
#       "id": "researcher",
#       "displayName": "调研助手",
#       "model": "deepseek-chat",
#       "toolWhitelist": ["web_fetch", "web_search", "memory_search"]
#     }
#   ]
# }
# 其中 model 字段：
#   "primary" → 使用环境变量配置（BELLDANDY_OPENAI_*）
#   其他值 → 引用 models.json 中对应 id 的条目
# 不创建此文件时，系统只有一个 default Agent，行为与之前完全一致
# BELLDANDY_AGENT_CONFIG_FILE=~/.belldandy/agents.json

# 子 Agent 最大并发数（默认 3，超出的任务自动排队）
# BELLDANDY_SUB_AGENT_MAX_CONCURRENT=3

# 排队队列最大长度（默认 10，队列满时拒绝新任务）
# BELLDANDY_SUB_AGENT_MAX_QUEUE_SIZE=10

# 子 Agent 运行超时（毫秒，默认 120000 即 2 分钟）
# BELLDANDY_SUB_AGENT_TIMEOUT_MS=120000

# 子 Agent 嵌套委托最大深度（默认 2，防止无限递归）
# BELLDANDY_SUB_AGENT_MAX_DEPTH=2

# ========================================
# 语音识别 (STT) 配置
# ========================================
# Provider: openai | groq | dashscope（默认 openai）
# BELLDANDY_STT_PROVIDER=openai

# 语言提示（默认 zh）
# BELLDANDY_STT_LANGUAGE=zh

# Aliyun DashScope 语音识别的 Key
# DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Groq STT（如果不使用 OpenAI）
# BELLDANDY_STT_GROQ_API_KEY=gsk_xxx
# BELLDANDY_STT_GROQ_BASE_URL=https://api.groq.com/openai/v1

# ========================================
# 身份上下文系统配置（可选）
# ========================================
# 智能注入阈值：房间成员数 ≤ 此值时，在 System Prompt 中注入完整成员列表
# 房间成员数 > 此值时，仅注入统计信息，Agent 需调用工具查询详细信息
# 默认值：10（推荐值，平衡体验与 token 消耗）
# 调优建议：
# - 设为 5：更激进的 token 节省，但小型房间也需要调用工具
# - 设为 15：更好的用户体验，但中型房间 token 消耗增加
# BELLDANDY_ROOM_INJECT_THRESHOLD=10

# 房间成员列表缓存有效期（毫秒）
# 默认值：300000（5分钟）
# 说明：在同一会话中多次查询成员列表时，使用缓存可大幅节省 token
# 调优建议：
# - 成员变动频繁的场景：设为 60000（1分钟）
# - 成员变动不频繁的场景：设为 600000（10分钟）
# BELLDANDY_ROOM_MEMBERS_CACHE_TTL=300000

# ========================================
# 其他配置
# ========================================
# 自动打开浏览器（启动时）
# AUTO_OPEN_BROWSER=true

# Setup 向导 Token（自动打开浏览器的魔法链接）
# SETUP_TOKEN=

# ========================================
# Tailscale 远程访问（可选）
# ========================================
# 从 https://login.tailscale.com/admin/settings/keys 获取 Auth Key
# 使用方法: docker-compose --profile tailscale up -d
# TAILSCALE_AUTH_KEY=tskey-auth-xxxxx
# TAILSCALE_EXTRA_ARGS=--ssh  # 启用 SSH 访问（可选）

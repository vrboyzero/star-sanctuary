# ============================================
# Star Sanctuary 环境变量配置模板
# ============================================
# 使用说明：
# 1. 本地开发：复制为 .env.local（Git 忽略）
# 2. Docker 部署：复制为 .env
# 3. 填写必需的配置项（标记为 REQUIRED）

# ========================================
# Docker 镜像配置（仅 Docker 部署需要）
# ========================================
BELLDANDY_IMAGE=vrboyzero/star-sanctuary:local

# ========================================
# 网络配置
# ========================================
# 绑定地址（127.0.0.1=仅本机，0.0.0.0=允许局域网访问）
BELLDANDY_HOST=127.0.0.1

# Gateway 端口
BELLDANDY_PORT=28889
BELLDANDY_GATEWAY_PORT=28889  # Docker Compose 使用此变量

# 版本检查（默认开启，仅日志提示，不自动升级）
BELLDANDY_UPDATE_CHECK=true
# BELLDANDY_UPDATE_CHECK_TIMEOUT_MS=3000
# BELLDANDY_UPDATE_CHECK_API_URL=https://api.github.com/repos/vrboyzero/star-sanctuary/releases/latest

# ========================================
# 认证配置（REQUIRED）
# ========================================
# 认证模式: none / token / password（默认 none）
# 注意：即使是 none，新设备连接也需要 Pairing 配对
# 警告：使用 0.0.0.0 时禁止使用 none 模式
BELLDANDY_AUTH_MODE=none

# Token 认证（当 AUTH_MODE=token 时必填）
# 生成方法: openssl rand -hex 32
BELLDANDY_AUTH_TOKEN=your-secure-token-here

# 密码认证（当 AUTH_MODE=password 时必填）
# BELLDANDY_AUTH_PASSWORD=your-secure-password-here

# Community API（/api/message）配置
# 默认关闭；仅在需要被 office.goddess.ai 等 HTTP 调用时开启
# 安全约束：当 BELLDANDY_COMMUNITY_API_ENABLED=true 时，BELLDANDY_AUTH_MODE 不能为 none（建议 token）
BELLDANDY_COMMUNITY_API_ENABLED=false
# 社区 API 专用 token（推荐与 AUTH_TOKEN 区分）
# 不设置时会回退到 BELLDANDY_AUTH_TOKEN
# BELLDANDY_COMMUNITY_API_TOKEN=your-community-api-token
# 调用方需携带请求头：
# Authorization: Bearer <BELLDANDY_COMMUNITY_API_TOKEN>
# 示例（本地联调）：
# curl -X POST http://127.0.0.1:28889/api/message -H "Authorization: Bearer your-community-api-token" -H "Content-Type: application/json" -d "{\"text\":\"hello\",\"conversationId\":\"conv-1\"}"

# Token 消耗上传到 office.goddess.ai（默认关闭）
# 作用：把每次新增的 token 消耗（delta）上报给 office 的 /api/internal/token-usage
# 使用步骤（通俗版）：
# 1) 先把 ENABLED 改成 true
# 2) URL 填 office 后端地址（通常是 http://127.0.0.1:3001/api/internal/token-usage）
# 3) APIKEY 填“该用户在 office.goddess.ai 里生成的 API Key 明文（gro_...）”
# 4) Star Sanctuary 会自动带请求头：Authorization: Bearer <APIKEY>
# 5) office 后端会用这个 API Key 反查归属用户并累计到该用户账号
BELLDANDY_TOKEN_USAGE_UPLOAD_ENABLED=false
# 接收端接口（office 内部路由）
# BELLDANDY_TOKEN_USAGE_UPLOAD_URL=http://127.0.0.1:3001/api/internal/token-usage
# 上传鉴权 API Key（推荐：每用户独立 key，便于单独吊销）
# BELLDANDY_TOKEN_USAGE_UPLOAD_APIKEY=gro_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 上传超时（毫秒，默认 3000）
# BELLDANDY_TOKEN_USAGE_UPLOAD_TIMEOUT_MS=3000

# WebSocket Origin 白名单（逗号分隔，防 CSWSH 攻击）
# 作用：限制哪些网页/客户端可以连接到 Star Sanctuary Gateway
# 默认行为：若不设置，本地开发环境（HOST=127.0.0.1）自动允许 localhost/127.0.0.1
# 配置建议：
# - 纯本地使用（命令行）：不需要配置
# - 本地 Web 开发：BELLDANDY_ALLOWED_ORIGINS=http://localhost:5173
# - 公网部署/生产环境：BELLDANDY_ALLOWED_ORIGINS=https://console.belldandy.ai
# BELLDANDY_ALLOWED_ORIGINS=http://localhost:3000,https://app.example.com

# ========================================
# WebChat 附件限制
# ========================================
# 单个附件大小上限（字节，默认 10MB）
# BELLDANDY_ATTACHMENT_MAX_FILE_BYTES=10485760

# 单次消息所有附件总大小上限（字节，默认 30MB）
# BELLDANDY_ATTACHMENT_MAX_TOTAL_BYTES=31457280

# 单个文本附件注入到 prompt 的字符上限（默认 200000）
# 作用：限制单个 txt/md/json/js/ts/log 等文本附件被直接拼进上下文的长度
# BELLDANDY_ATTACHMENT_TEXT_CHAR_LIMIT=200000

# 单次消息所有文本附件 + 音频转录注入 prompt 的总字符预算（默认 200000）
# 作用：避免多个长文本附件或长转录内容线性放大 token 成本
# BELLDANDY_ATTACHMENT_TEXT_TOTAL_CHAR_LIMIT=200000

# 当用户已有文本输入时，单个音频转录作为“追加上下文”写入 prompt 的字符上限（默认 12000）
# 如果用户没有手动输入文本，音频转录仍可作为主 prompt，但仍受总字符预算约束
# BELLDANDY_AUDIO_TRANSCRIPT_APPEND_CHAR_LIMIT=12000

# ========================================
# Agent 配置（REQUIRED）
# ========================================
# Agent 提供商: mock / openai（默认 mock）
BELLDANDY_AGENT_PROVIDER=openai

# OpenAI 兼容 API 配置
# 支持 OpenAI、Gemini、DeepSeek、Ollama 等兼容服务
BELLDANDY_OPENAI_BASE_URL=https://api.openai.com/v1
BELLDANDY_OPENAI_API_KEY=sk-your-api-key-here
BELLDANDY_OPENAI_MODEL=gpt-4o

# Kimi K2.5 (Vision Support) 配置示例:
# BELLDANDY_OPENAI_BASE_URL=https://api.moonshot.cn/v1
# BELLDANDY_OPENAI_API_KEY=sk-xxxxxxxx
# BELLDANDY_OPENAI_MODEL=kimi-k2.5-preview

# 流式输出（默认 true）
# BELLDANDY_OPENAI_STREAM=true

# OpenAI 线路协议：chat_completions（默认）| responses
# 使用 aicodewith 的 gpt-5.3-codex 时通常需要设置为 responses
# BELLDANDY_OPENAI_WIRE_API=responses
# 仅在 responses + tools 模式下清洗工具 schema，移除 oneOf/$ref 等不兼容关键字
# 某些代理（如部分 aicodewith 路由）在 tools 模式下需要开启
# BELLDANDY_RESPONSES_SANITIZE_TOOL_SCHEMA=true
# OpenAI 默认重试次数（不含首次请求，默认 0）
# 仅对可重试错误生效（timeout/429/5xx/网络异常）
# BELLDANDY_OPENAI_MAX_RETRIES=1
# OpenAI 默认重试退避基线（毫秒，默认 300）
# 实际退避采用指数退避，最大约 5 秒
# BELLDANDY_OPENAI_RETRY_BACKOFF_MS=300
# OpenAI primary 专用代理 URL（可选）
# 用于网络受限场景；fallback 可在 models.json 里按模型单独覆盖 proxyUrl
# BELLDANDY_OPENAI_PROXY_URL=http://127.0.0.1:7890
# 启动时 primary 预热探测（失败会给 primary 加短期冷却，默认 true）
# BELLDANDY_PRIMARY_WARMUP_ENABLED=true
# 预热探测请求超时（毫秒，默认 8000）
# BELLDANDY_PRIMARY_WARMUP_TIMEOUT_MS=8000
# 预热失败后 primary 的冷却时间（毫秒，默认 60000）
# BELLDANDY_PRIMARY_WARMUP_COOLDOWN_MS=60000

# 额外的系统提示词（追加到 workspace prompt 之后）
# BELLDANDY_OPENAI_SYSTEM_PROMPT=

# 单次模型调用超时（毫秒，默认 120000 即 2 分钟，最小 5000）
# BELLDANDY_AGENT_TIMEOUT_MS=120000

# API 协议：openai | anthropic（默认自动检测）
# 如果 BELLDANDY_OPENAI_BASE_URL 包含 anthropic.com，prompt caching 会自动启用
# 使用 Anthropic 原生协议可启用 Prompt Caching，显著降低 token 消耗和限流风险
# BELLDANDY_AGENT_PROTOCOL=anthropic

# ========================================
# 视频文件上传（Video File Upload）
# ========================================
# 当聊天代理（OPENAI_BASE_URL）不支持 Moonshot /files 端点时，
# 设置此项让视频上传走 Moonshot 直连 API。
# 仅设置 URL 时，API Key 回退到 BELLDANDY_OPENAI_API_KEY。
# BELLDANDY_VIDEO_FILE_API_URL=https://api.moonshot.cn/v1
# BELLDANDY_VIDEO_FILE_API_KEY=sk-xxx

# ========================================
# 模型容灾 (Model Failover)
# ========================================
# 备用模型配置文件路径（JSON 格式，默认 ~/.star_sanctuary/models.json）
# 配置后，主模型限流/故障时自动切换到备用模型，在不使用默认路径时才需要配置以下变量。
# 字段优先级（高→低）：
# 1) models.json 每个 fallback 的字段（wireApi/requestTimeoutMs/maxRetries/retryBackoffMs/proxyUrl）
# 2) 全局环境变量（BELLDANDY_OPENAI_*）
# 注意：primary 来自 .env，不在 models.json 的 fallbacks 中定义。
#
# 最小格式示例：
# {
#   "fallbacks": [
#     {
#       "id": "backup",
#       "baseUrl": "https://api.deepseek.com/v1",
#       "apiKey": "sk-xxx",
#       "model": "deepseek-chat",
#       "protocol": "openai",
#       "wireApi": "chat_completions",
#       "requestTimeoutMs": 60000,
#       "maxRetries": 1,
#       "retryBackoffMs": 300,
#       "proxyUrl": "http://127.0.0.1:7890"
#     }
#   ]
# }
#
# “主稳 + gpt fallback” 示例（primary 走 .env 的稳定模型）：
# {
#   "fallbacks": [
#     {
#       "id": "gpt-5.3-codex",
#       "baseUrl": "https://api.aicodewith.com/chatgpt/v1",
#       "apiKey": "sk-xxx",
#       "model": "gpt-5.3-codex",
#       "protocol": "openai",
#       "wireApi": "responses",
#       "requestTimeoutMs": 60000,
#       "maxRetries": 1,
#       "retryBackoffMs": 400
#     },
#     {
#       "id": "kimi-k2.5-relay",
#       "baseUrl": "https://aiping.cn/api/v1",
#       "apiKey": "sk-xxx",
#       "model": "kimi-k2.5",
#       "protocol": "openai",
#       "wireApi": "chat_completions",
#       "requestTimeoutMs": 90000,
#       "maxRetries": 1,
#       "retryBackoffMs": 300
#     }
#   ]
# }
# BELLDANDY_MODEL_CONFIG_FILE=~/.star_sanctuary/models.json

# ========================================
# Embedding 配置（向量检索）
# ========================================
# 启用向量检索（需配置 Embedding 模型）
BELLDANDY_EMBEDDING_ENABLED=false

# Embedding 提供商选择: openai | local（默认 openai）
BELLDANDY_EMBEDDING_PROVIDER=openai

# OpenAI Embedding 模型
BELLDANDY_EMBEDDING_MODEL=text-embedding-3-small

# 本地 Embedding 模型名称（仅当 provider=local 时生效）
# 默认使用 "BAAI/bge-m3"，这是一款性能非常强大的多语言模型
# 模型会自动下载并保存到工作区目录下的 .star_sanctuary/models 文件夹中
# BELLDANDY_LOCAL_EMBEDDING_MODEL=BAAI/bge-base-en-v1.5

# Embedding API 配置（留空则使用 BELLDANDY_OPENAI_* 配置）
# BELLDANDY_EMBEDDING_OPENAI_API_KEY=
# BELLDANDY_EMBEDDING_OPENAI_BASE_URL=

# Embedding 批处理大小（默认 2）
# 减小此值可避免 413 Payload Too Large 错误
BELLDANDY_EMBEDDING_BATCH_SIZE=2

# Context Injection（对话开始时自动注入最近记忆摘要）
# 启用后，每次对话开始时会自动从记忆库取最近 N 条记忆注入上下文，让 Agent "记住"近期事件
# 设为 false 可关闭（默认启用）
# BELLDANDY_CONTEXT_INJECTION=true

# 注入的记忆条数（默认 5）
# BELLDANDY_CONTEXT_INJECTION_LIMIT=5

# 是否允许把 session 类型短期会话记忆也注入上下文（默认 false）
# 建议保持关闭，避免把刚完成的执行步骤再次塞回上下文，引导 Agent 重复执行。
# BELLDANDY_CONTEXT_INJECTION_INCLUDE_SESSION=false

# 附带注入最近已完成任务的摘要条数（默认 3）
# 用于提醒 Agent 近期哪些任务已经做过，避免重复重启服务/重复跑命令。
# BELLDANDY_CONTEXT_INJECTION_TASK_LIMIT=3

# 自动注入时允许进入上下文的记忆分类（默认 preference,fact,decision,entity）
# 可选值：preference,fact,decision,entity,experience,other
# BELLDANDY_CONTEXT_INJECTION_ALLOWED_CATEGORIES=preference,fact,decision,entity

# Task 去重守卫：阻止最近已成功执行过的相同工具动作再次执行（默认 true）
# 可通过工具参数 retry=true / force=true / allowDuplicate=true 显式绕过。
# BELLDANDY_TASK_DEDUP_GUARD_ENABLED=true

# Task 去重守卫的时间窗口，单位分钟（默认 20）
# BELLDANDY_TASK_DEDUP_WINDOW_MINUTES=20

# Task 去重全局模式（默认 graded）
# 可选值：
# - off：关闭默认去重（仍可配合 BELLDANDY_TASK_DEDUP_POLICY 对个别工具单独开启）
# - graded：使用内置分级策略
# - strict：把内置 warn-only 工具也提升为 hard-block
# BELLDANDY_TASK_DEDUP_MODE=graded

# Task 去重策略覆盖（可选，逗号分隔）
# 格式：toolName:mode,toolName:mode
# mode 可选：hard-block | warn-only | off
# 默认内置策略：
# service_restart:hard-block,switch_facet:hard-block,method_create:hard-block,run_command:warn-only,file_write:warn-only,file_delete:warn-only
# 示例：
# BELLDANDY_TASK_DEDUP_POLICY=run_command:off,file_write:hard-block
# BELLDANDY_TASK_DEDUP_POLICY=service_restart:hard-block,run_command:warn-only,file_write:off
# BELLDANDY_TASK_DEDUP_POLICY=
#
# 常用组合示例：
# 1) 默认推荐：
# BELLDANDY_TASK_DEDUP_MODE=graded
# BELLDANDY_TASK_DEDUP_POLICY=
#
# 2) 保留重启/切面/方法创建强拦截，但允许重复跑命令：
# BELLDANDY_TASK_DEDUP_MODE=graded
# BELLDANDY_TASK_DEDUP_POLICY=run_command:off
#
# 3) 对文件落盘更保守，写入和删除都改为强拦截：
# BELLDANDY_TASK_DEDUP_MODE=graded
# BELLDANDY_TASK_DEDUP_POLICY=file_write:hard-block,file_delete:hard-block
#
# 4) 最保守模式：内置 warn-only 工具也统一升级为 hard-block
# BELLDANDY_TASK_DEDUP_MODE=strict
# BELLDANDY_TASK_DEDUP_POLICY=

# Auto-Recall（底层自动语义召回，默认关闭）
# 启用后，在 before_agent_start 阶段会基于用户原始输入自动执行 memory search，并静默注入相关历史记忆
# BELLDANDY_AUTO_RECALL_ENABLED=false

# Auto-Recall 每次最多注入的结果条数（默认 3）
# BELLDANDY_AUTO_RECALL_LIMIT=3

# Auto-Recall 最低相关性阈值（默认 0.3）
# BELLDANDY_AUTO_RECALL_MIN_SCORE=0.3

# 工具结果写回 transcript 的字符上限（默认 12000）
# 作用：当单次工具输出特别长时，只保留前后文摘要片段，避免下一轮模型把整段大输出再次吃进上下文
# BELLDANDY_TOOL_RESULT_TRANSCRIPT_CHAR_LIMIT=12000

# ========================================
# 记忆系统增强（Phase M-Next）
# ========================================
# L0 摘要层：索引后自动为长 chunk 生成 LLM 摘要，memory_search 默认返回摘要以节省 token
# BELLDANDY_MEMORY_SUMMARY_ENABLED=false

# 摘要生成用的模型（建议小模型以降低成本，默认继承主模型）
# BELLDANDY_MEMORY_SUMMARY_MODEL=gpt-4o-mini

# 摘要 API 地址和密钥（可选，默认继承主模型配置）
# BELLDANDY_MEMORY_SUMMARY_BASE_URL=
# BELLDANDY_MEMORY_SUMMARY_API_KEY=

# 会话记忆自动提取：会话结束后自动分析对话，提取用户偏好和经验教训写入每日记忆文件
# BELLDANDY_MEMORY_EVOLUTION_ENABLED=false

# Session Digest 刷新预算：限制窗口期内允许执行的 digest 刷新次数（默认不限制）
# 适用范围：conversation.digest.refresh 以及 message.send / message.error 后的自动 digest refresh
# BELLDANDY_MEMORY_SESSION_DIGEST_MAX_RUNS=

# Session Digest 刷新预算窗口（毫秒，默认 3600000 = 1 小时）
# 仅在设置了 BELLDANDY_MEMORY_SESSION_DIGEST_MAX_RUNS 时生效
# BELLDANDY_MEMORY_SESSION_DIGEST_WINDOW_MS=3600000

# Durable Extraction 后台调度预算：限制窗口期内允许进入后台 extraction 调度的次数（默认不限制）
# 适用范围：conversation.memory.extract 与 digest 更新后触发的 durable extraction 调度
# BELLDANDY_MEMORY_DURABLE_EXTRACTION_MAX_RUNS=

# Durable Extraction 后台调度预算窗口（毫秒，默认 3600000 = 1 小时）
# 仅在设置了 BELLDANDY_MEMORY_DURABLE_EXTRACTION_MAX_RUNS 时生效
# BELLDANDY_MEMORY_DURABLE_EXTRACTION_WINDOW_MS=3600000

# Durable Extraction 细化触发阈值：最少待处理消息数（默认 0 = 不额外限制）
# 当 pending message 数量低于此值时，runtime 会跳过本轮 extraction 调度
# BELLDANDY_MEMORY_DURABLE_EXTRACTION_MIN_PENDING_MESSAGES=0

# Durable Extraction 细化触发阈值：距离上次成功提取后，至少新增多少条消息才再次触发（默认 0 = 不额外限制）
# 适合降低短对话或碎片更新导致的频繁重复提取
# BELLDANDY_MEMORY_DURABLE_EXTRACTION_MIN_MESSAGE_DELTA=0

# Durable Extraction 成功冷却窗口（毫秒，默认 0 = 成功后不额外冷却）
# 设置后，成功完成一次 extraction 后，到冷却结束前不会再次进入调度
# BELLDANDY_MEMORY_DURABLE_EXTRACTION_SUCCESS_COOLDOWN_MS=0

# Durable Extraction 失败退避基线（毫秒，默认沿用 runtime retryDelay，当前约 2000）
# 连续失败时会按指数退避增长，避免持续失败时高频重试
# BELLDANDY_MEMORY_DURABLE_EXTRACTION_FAILURE_BACKOFF_MS=2000

# Durable Extraction 失败退避上限（毫秒，默认 60000）
# BELLDANDY_MEMORY_DURABLE_EXTRACTION_FAILURE_BACKOFF_MAX_MS=60000

# 示例：把 Durable Extraction 调得更保守，减少短对话抖动与连续失败重试
# BELLDANDY_MEMORY_DURABLE_EXTRACTION_MIN_PENDING_MESSAGES=6
# BELLDANDY_MEMORY_DURABLE_EXTRACTION_MIN_MESSAGE_DELTA=4
# BELLDANDY_MEMORY_DURABLE_EXTRACTION_SUCCESS_COOLDOWN_MS=300000
# BELLDANDY_MEMORY_DURABLE_EXTRACTION_FAILURE_BACKOFF_MS=5000
# BELLDANDY_MEMORY_DURABLE_EXTRACTION_FAILURE_BACKOFF_MAX_MS=600000

# Team Shared Memory（当前仅前置条件工程化，默认关闭）
# 启用后会把 stateDir/team-memory 纳入 MemoryManager 索引源，并开放 doctor/readiness 诊断
# 当前只包含本地 path 规范、secret guard、最小索引挂接；不包含远端 sync / watcher / 服务端闭环
# BELLDANDY_TEAM_SHARED_MEMORY_ENABLED=false

# 示例：启用本地 team-memory 索引，用于共享记忆前置条件验证
# BELLDANDY_TEAM_SHARED_MEMORY_ENABLED=true

# 触发提取的最少消息数（默认 4，过短的对话不提取）
# BELLDANDY_MEMORY_EVOLUTION_MIN_MESSAGES=4

# 提取用的模型（可选，默认继承主模型）
# BELLDANDY_MEMORY_EVOLUTION_MODEL=gpt-4o-mini

# 提取 API 地址和密钥（可选，默认继承主模型配置）
# BELLDANDY_MEMORY_EVOLUTION_BASE_URL=
# BELLDANDY_MEMORY_EVOLUTION_API_KEY=

# Task Memory：记录任务级执行结果（默认关闭）
# 开启后会按 conversation 记录 objective、toolCalls、memoryLinks、artifactPaths 等任务层数据，
# 供 Memory Viewer 的 Tasks 视图使用；不会改写现有 chunk 记忆结构。
# 仅想收集任务元数据时，开启 TASK_MEMORY 即可，不必同时开启 TASK_SUMMARY。
# BELLDANDY_TASK_MEMORY_ENABLED=false

# Task Summary：为满足阈值的任务生成 LLM 总结（默认关闭）
# 开启后，仅对“耗时较长 / 工具调用较多 / token 消耗较高”的任务补一段总结。
# 建议先启用 TASK_MEMORY 观察样本，再决定是否启用 TASK_SUMMARY。
# BELLDANDY_TASK_SUMMARY_ENABLED=false

# Task Summary 使用的模型（可选，默认继承主模型）
# 建议优先使用稳定的文本聊天模型，例如 moonshot-v1-8k / moonshot-v1-32k
# 不建议使用 embedding 模型（如 text-embedding-v4）或 vision-preview 模型
# BELLDANDY_TASK_SUMMARY_MODEL=moonshot-v1-8k

# Task Summary API 地址和密钥（可选，默认继承主模型配置）
# BELLDANDY_TASK_SUMMARY_BASE_URL=
# BELLDANDY_TASK_SUMMARY_API_KEY=

# Task Summary 触发阈值（满足其一即可触发，总结前提仍需 TASK_MEMORY_ENABLED=true）
# 最小任务耗时（毫秒，默认 15000）
# BELLDANDY_TASK_SUMMARY_MIN_DURATION_MS=15000
# 最小工具调用次数（默认 2）
# BELLDANDY_TASK_SUMMARY_MIN_TOOL_CALLS=2
# 最小总 token 消耗（默认 2000）
# BELLDANDY_TASK_SUMMARY_MIN_TOKEN_TOTAL=2000

# 示例 1：只启用 Task Viewer 数据沉淀，不做 LLM 总结
# BELLDANDY_TASK_MEMORY_ENABLED=true
# BELLDANDY_TASK_SUMMARY_ENABLED=false

# 示例 2：启用 Task Memory + 高价值任务总结
# BELLDANDY_TASK_MEMORY_ENABLED=true
# BELLDANDY_TASK_SUMMARY_ENABLED=true
# BELLDANDY_TASK_SUMMARY_MODEL=moonshot-v1-32k
# BELLDANDY_TASK_SUMMARY_MIN_DURATION_MS=30000
# BELLDANDY_TASK_SUMMARY_MIN_TOOL_CALLS=3
# BELLDANDY_TASK_SUMMARY_MIN_TOKEN_TOTAL=4000

# 第五阶段：Method / Skill 半自动沉淀（默认开启）
# 前提：需要先开启 TASK_MEMORY，否则不会记录 task，自然也不会生成候选。
# 当前自动生成只会写入 experience_candidates 候选层，不会自动发布到正式 methods/ 或用户 skills/。
# 当前自动生成走规则化提炼，不直接依赖 TASK_SUMMARY_MODEL。
# TASK_SUMMARY 只是在开启后补强 task 的 summary/reflection/outcome，从而间接提升候选质量。
BELLDANDY_EXPERIENCE_AUTO_PROMOTION_ENABLED=true

# 自动生成 method 候选（默认开启）
BELLDANDY_EXPERIENCE_AUTO_METHOD_ENABLED=true

# 自动生成 skill 候选草稿（默认开启）
BELLDANDY_EXPERIENCE_AUTO_SKILL_ENABLED=true

# 示例 3：只自动沉淀 method，关闭 skill 自动草稿
# BELLDANDY_TASK_MEMORY_ENABLED=true
# BELLDANDY_EXPERIENCE_AUTO_PROMOTION_ENABLED=true
# BELLDANDY_EXPERIENCE_AUTO_METHOD_ENABLED=true
# BELLDANDY_EXPERIENCE_AUTO_SKILL_ENABLED=false

# 源路径聚合检索：搜索时对高频命中的文件自动拉取上下文 chunk，提升长文档检索连贯性
# BELLDANDY_MEMORY_DEEP_RETRIEVAL=false

# Task-aware Embedding 前缀（用于 Jina/BGE 等支持 task 参数的模型）
# 查询时在文本前添加 queryPrefix，索引时添加 passagePrefix，可提升检索相关性 5-15%
# BGE 系列示例: BELLDANDY_EMBEDDING_QUERY_PREFIX="query: "  BELLDANDY_EMBEDDING_PASSAGE_PREFIX="passage: "
# Jina 系列示例: BELLDANDY_EMBEDDING_QUERY_PREFIX="retrieval.query: "  BELLDANDY_EMBEDDING_PASSAGE_PREFIX="retrieval.passage: "
# 不设置则不添加前缀（兼容 OpenAI text-embedding 等不需要前缀的模型）
# BELLDANDY_EMBEDDING_QUERY_PREFIX=
# BELLDANDY_EMBEDDING_PASSAGE_PREFIX=

# Reranker 配置
# 硬截断最低分数，低于此分数的检索结果直接丢弃（默认 0.15）
# BELLDANDY_RERANKER_MIN_SCORE=0.15
# 长度归一化锚点（字符数），防止长文本靠关键词密度霸榜（默认 500，0 表示不归一化）
# BELLDANDY_RERANKER_LENGTH_NORM_ANCHOR=500

# ========================================
# 功能开关
# ========================================
# 启用工具调用（ReAct 循环；联网、读写文件等,false/true）
BELLDANDY_TOOLS_ENABLED=true

# 仅在 responses + tools 模式下清洗工具 schema，移除 oneOf/$ref 等不兼容关键字
# 某些代理（如部分 aicodewith 路由）在 tools 模式下需要开启
BELLDANDY_RESPONSES_SANITIZE_TOOL_SCHEMA=true

# Agent 是否可控制已注册工具的全局 disabled 列表
# - disabled: 禁止 Agent 修改工具开关
# - confirm: Agent 发起后，需用户回复固定文本口令确认
# - auto: Agent 可直接修改全局工具开关
BELLDANDY_AGENT_TOOL_CONTROL_MODE=confirm

# 工具开关确认密码（仅在 BELLDANDY_AGENT_TOOL_CONTROL_MODE=confirm 时生效）
# - 留空：沿用“批准工具设置变更 <requestId>”确认口令
# - 已设置：用户改为输入这里配置的确认口令；系统不会回显该口令
BELLDANDY_AGENT_TOOL_CONTROL_CONFIRM_PASSWORD=

# 工具分组加载（默认 all 加载全部，逗号分隔可选组）
# 可选组：browser（浏览器自动化）, multimedia（摄像头/图片生成/TTS）, methodology（方法论SOP）, system（日志/定时任务/重启/模组切换）
# core 组（file/fetch/memory/apply_patch）始终加载，无需指定
# 使用中转代理时建议只加载需要的组以减少 token 消耗
# 示例：BELLDANDY_TOOL_GROUPS=core（只加载核心工具）
# 示例：BELLDANDY_TOOL_GROUPS=browser,system（加载核心+浏览器+系统工具）
# BELLDANDY_TOOL_GROUPS=all

# 最大输入 token 数限制（超过时自动裁剪历史消息，0 或不设表示不限制）
# 使用有输入长度限制的中转代理时建议设置，如 BELLDANDY_MAX_INPUT_TOKENS=20000
# 文本附件会按单文件 200000 字符截断后注入；当文本附件累计字符 >=12000/30000 时，
# 请求超时下限会自动提升到 120s/300s（普通文本请求不受影响）
# BELLDANDY_MAX_INPUT_TOKENS=0

# 单次模型调用最大输出 token 数（默认 4096）
# 建议调大到 8192 或更高，避免模型在生成长内容（如大型工具调用 JSON）时被截断
# 截断会导致工具参数残缺，引发 file_write "path 必须是非空字符串" 等错误
# BELLDANDY_MAX_OUTPUT_TOKENS=4096

# 启用记忆系统
BELLDANDY_MEMORY_ENABLED=true

# 记忆数据库路径
# BELLDANDY_MEMORY_DB=~/.star_sanctuary/memory.db

# 启用 MCP 协议支持
BELLDANDY_MCP_ENABLED=false

# 启用浏览器自动化
BELLDANDY_BROWSER_RELAY_ENABLED=false

# 浏览器 Relay 端口
# BELLDANDY_RELAY_PORT=28892

# 浏览器工具域名白名单（逗号分隔）
# 仅当启用浏览器自动化时生效；配置后只允许访问这些域名及其子域名
# 适合把浏览器能力限制在文档站、代码托管站、业务后台等明确站点
# 示例：BELLDANDY_BROWSER_ALLOWED_DOMAINS=github.com,developer.mozilla.org,docs.example.com
# BELLDANDY_BROWSER_ALLOWED_DOMAINS=

# 浏览器工具域名黑名单（逗号分隔，优先级高于白名单）
# 适合显式禁止邮箱、网盘、支付、管理后台等高风险站点
# 示例：BELLDANDY_BROWSER_DENIED_DOMAINS=mail.google.com,drive.google.com,onedrive.live.com
# BELLDANDY_BROWSER_DENIED_DOMAINS=

# 启用定时任务
BELLDANDY_CRON_ENABLED=false

# 启用心跳检查
BELLDANDY_HEARTBEAT_ENABLED=false

# 心跳检查间隔（支持 30m, 1h, 300s 格式）
# BELLDANDY_HEARTBEAT_INTERVAL=30m

# 心跳活跃时间窗口（例如 08:00-23:00）
# BELLDANDY_HEARTBEAT_ACTIVE_HOURS=

# ------ Webhook API（外部系统触发）------
# Webhook 配置文件路径（默认 ~/.star_sanctuary/webhooks.json）
# 配置后可通过 HTTP POST 触发 Agent，适用于 CI/CD、监控告警、定时任务等场景
# BELLDANDY_WEBHOOK_CONFIG_PATH=~/.star_sanctuary/webhooks.json
# Webhook 幂等性时间窗口（毫秒，默认 600000 即 10 分钟）
# 通过 X-Idempotency-Key 请求头防止重复执行
# BELLDANDY_WEBHOOK_IDEMPOTENCY_WINDOW_MS=600000
# 使用示例：
# curl -X POST http://127.0.0.1:28889/api/webhook/ci-alert \
#   -H "Authorization: Bearer your-token" \
#   -H "Content-Type: application/json" \
#   -H "X-Idempotency-Key: unique-event-id" \
#   -d '{"text": "CI 构建失败"}'
# 详细文档：docs/webhook.md

# ========================================
# 数据持久化路径
# ========================================
# 状态目录（配置、会话、记忆数据库；同时是 file_read/file_write/file_delete 的工作区根目录）
# 通用场景可直接设置 BELLDANDY_STATE_DIR；当同一仓库要在 Windows / WSL 分别维护独立运行态时，
# 可改用下面两个平台专用变量：
BELLDANDY_STATE_DIR=~/.star_sanctuary
# BELLDANDY_STATE_DIR_WINDOWS=C:\Users\your-name\.star_sanctuary
# BELLDANDY_STATE_DIR_WSL=~/.star_sanctuary

# 工作区目录（文件工具访问范围，Docker 部署使用）
BELLDANDY_WORKSPACE_DIR=./workspace

# 额外允许 Agent 读写的根目录（逗号分隔，如其他盘符下的目录）
# 不设则仅限上面状态目录
# BELLDANDY_EXTRA_WORKSPACE_ROOTS=E:\tools,D:\projects

# WebChat 静态文件路径（通常无需修改）
# BELLDANDY_WEB_ROOT=apps/web/public

# ========================================
# 日志配置
# ========================================
# 最低日志级别 (debug/info/warn/error)，可以通过设置 BELLDANDY_LOG_LEVEL=info 来过滤掉所有 debug 级别的浏览器日志。
BELLDANDY_LOG_LEVEL=info
# 是否输出到控制台 / 是否写入文件
BELLDANDY_LOG_CONSOLE=true
BELLDANDY_LOG_FILE=true

# 日志目录
BELLDANDY_LOG_DIR=~/.star_sanctuary/logs

# 单个日志文件最大大小（触发轮转）
BELLDANDY_LOG_MAX_SIZE=10MB

# 日志保留天数（自动清理）
BELLDANDY_LOG_RETENTION_DAYS=7

# ========================================
# 工具与安全配置
# ========================================
# 危险工具开关（run_command）
# BELLDANDY_DANGEROUS_TOOLS_ENABLED=false

# 工具策略配置文件（覆盖默认工具策略）
# BELLDANDY_TOOLS_POLICY_FILE=~/.star_sanctuary/tools-policy.json
# 示例文件：
# - config/tools-policy.strict.json：最保守档
# - config/tools-policy.balanced.json：平衡推荐档
# - config/tools-policy.open.json：受控开放档

# ========================================
# 对话压缩（Context Compaction）
# ========================================
# 是否启用上下文自动压缩（默认 true）
# 启用后，当历史消息 token 超过阈值时，自动将旧消息摘要化（三层渐进式压缩）
# BELLDANDY_COMPACTION_ENABLED=true

# 当历史消息的估算 token 数超过此阈值时，自动将旧消息摘要化以减少 token 消耗
# 默认 12000（约 12K tokens），设为 0 或不设表示不启用压缩
# 建议 Anthropic 模型设 8000，OpenAI 模型时设 20000
BELLDANDY_COMPACTION_THRESHOLD=20000

# 压缩时保留最近几条消息原文（默认 10）
BELLDANDY_COMPACTION_KEEP_RECENT=10

# ReAct 循环内压缩触发比例（默认 0.75，即上下文窗口使用 75% 时触发循环内压缩）
# 需配合 BELLDANDY_MAX_INPUT_TOKENS 使用
# BELLDANDY_COMPACTION_TRIGGER_FRACTION=0.75

# Rolling Summary 超过此 token 数时触发归档压缩（默认 2000）
# 归档压缩会将滚动摘要进一步浓缩为超简洁版本
# BELLDANDY_COMPACTION_ARCHIVAL_THRESHOLD=2000

# 摘要专用模型（可选，不设则复用主模型）
# 建议使用便宜/快速的模型（如 gpt-4o-mini）以降低成本
# BELLDANDY_COMPACTION_MODEL=gpt-4o-mini

# 摘要专用 API 地址和密钥（可选，不设则复用主模型的 BASE_URL / API_KEY）
# 当摘要模型与主模型不在同一服务商时需要配置
# BELLDANDY_COMPACTION_BASE_URL=https://api.openai.com/v1
# BELLDANDY_COMPACTION_API_KEY=sk-xxx

# ========================================
# TTS（语音合成）配置
# ========================================
# 启用语音模式（服务端自动将 Agent 回复转为语音，默认 false）
# BELLDANDY_TTS_ENABLED=false

# TTS 提供商: dashscope | edge (free) | openai
BELLDANDY_TTS_PROVIDER=edge

# 语音 ID: DashScope: Cherry | Edge: zh-CN-XiaoxiaoNeural | OpenAI: alloy
BELLDANDY_TTS_VOICE=zh-CN-XiaoxiaoNeural

# Aliyun DashScope TTS（可选）
# 获取 Key: https://help.aliyun.com/zh/model-studio/get-api-key
# DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ========================================
# 渠道配置
# ========================================
# Channels 路由引擎（默认关闭，开启后可按规则做 mention gating / agent 路由）
# BELLDANDY_CHANNEL_ROUTER_ENABLED=false
# 路由配置文件（JSON）
# BELLDANDY_CHANNEL_ROUTER_CONFIG_PATH=~/.star_sanctuary/channels-routing.json
# 路由默认 Agent ID（当规则未指定 agentId 时使用）
# BELLDANDY_CHANNEL_ROUTER_DEFAULT_AGENT_ID=default

# 飞书渠道配置
# BELLDANDY_FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
# BELLDANDY_FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 飞书渠道绑定的 Agent Profile ID（可选，默认使用 default Agent）
# 需先在 ~/.star_sanctuary/agents.json 中定义对应 profile
# BELLDANDY_FEISHU_AGENT_ID=researcher

# QQ 渠道配置
# BELLDANDY_QQ_APP_ID=xxxxxxxx
# BELLDANDY_QQ_APP_SECRET=xxxxxxxx
# 说明：当前运行时代码未消费 BELLDANDY_QQ_APP_TOKEN，因此这里不再保留该示例项

# QQ 渠道绑定的 Agent Profile ID（可选，默认使用 default Agent）
# BELLDANDY_QQ_AGENT_ID=default

# 默认开启沙箱环境（true/false）
# BELLDANDY_QQ_SANDBOX=true

# ----------------------------------------
# Discord 渠道配置
# ----------------------------------------
# 申请流程：https://discord.com/developers/applications
# 1. 创建 Application → 进入 Bot 页面 → Reset Token 获取 Bot Token
# 2. 开启 Privileged Gateway Intents：MESSAGE CONTENT INTENT（必须）
# 3. OAuth2 → URL Generator → Scopes: bot → 勾选 Send Messages / Read Message History 等权限 → 邀请到服务器
# 启用 Discord 渠道
# BELLDANDY_DISCORD_ENABLED=false

# Bot Token（在 Discord Developer Portal → Bot 页面获取）
# BELLDANDY_DISCORD_BOT_TOKEN=your-discord-bot-token-here

# 默认主动消息发送目标频道 ID（右键频道 → 复制频道 ID，需开启开发者模式）
# 用于心跳提醒、定时任务等主动推送场景；不设则使用最后活跃频道
# BELLDANDY_DISCORD_DEFAULT_CHANNEL_ID=

# ========================================
# 多 Agent 配置
# ========================================
# Agent 配置文件路径（JSON 格式，默认 ~/.star_sanctuary/agents.json）
# 配置多个 Agent 实例，每个可使用不同模型和工具白名单
# 格式参考:
# {
#   "agents": [
#     {
#       "id": "coder",
#       "displayName": "编程助手",
#       "model": "primary",
#       "toolWhitelist": ["file_read", "file_write", "run_command"]
#     },
#     {
#       "id": "researcher",
#       "displayName": "调研助手",
#       "model": "deepseek-chat",
#       "toolWhitelist": ["web_fetch", "web_search", "memory_search"]
#     }
#   ]
# }
# 其中 model 字段：
#   "primary" → 使用环境变量配置（BELLDANDY_OPENAI_*）
#   其他值 → 引用 models.json 中对应 id 的条目
# 不创建此文件时，系统只有一个 default Agent，行为与之前完全一致
# BELLDANDY_AGENT_CONFIG_FILE=~/.star_sanctuary/agents.json

# 子 Agent 最大并发数（默认 3，超出的任务自动排队）
# BELLDANDY_SUB_AGENT_MAX_CONCURRENT=3

# 排队队列最大长度（默认 10，队列满时拒绝新任务）
# BELLDANDY_SUB_AGENT_MAX_QUEUE_SIZE=10

# 子 Agent 运行超时（毫秒，默认 120000 即 2 分钟）
# BELLDANDY_SUB_AGENT_TIMEOUT_MS=120000

# 子 Agent 嵌套委托最大深度（默认 2，防止无限递归）
# BELLDANDY_SUB_AGENT_MAX_DEPTH=2

# ========================================
# 语音识别 (STT) 配置
# ========================================
# Provider: openai | groq | dashscope（默认 openai）
# BELLDANDY_STT_PROVIDER=openai

# 语言提示（默认 zh）
# BELLDANDY_STT_LANGUAGE=zh

# Aliyun DashScope 语音识别的 Key
# DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Groq STT（如果不使用 OpenAI）
# BELLDANDY_STT_GROQ_API_KEY=gsk_xxx
# BELLDANDY_STT_GROQ_BASE_URL=https://api.groq.com/openai/v1

# ========================================
# 身份上下文系统配置（可选）
# ========================================
# 智能注入阈值：房间成员数 ≤ 此值时，在 System Prompt 中注入完整成员列表
# 房间成员数 > 此值时，仅注入统计信息，Agent 需调用工具查询详细信息
# 默认值：10（推荐值，平衡体验与 token 消耗）
# 调优建议：
# - 设为 5：更激进的 token 节省，但小型房间也需要调用工具
# - 设为 15：更好的用户体验，但中型房间 token 消耗增加
# BELLDANDY_ROOM_INJECT_THRESHOLD=10

# 房间成员列表缓存有效期（毫秒）
# 默认值：300000（5分钟）
# 说明：在同一会话中多次查询成员列表时，使用缓存可大幅节省 token
# 调优建议：
# - 成员变动频繁的场景：设为 60000（1分钟）
# - 成员变动不频繁的场景：设为 600000（10分钟）
# BELLDANDY_ROOM_MEMBERS_CACHE_TTL=300000

# ========================================
# FACET 模组切换配置
# ========================================
# FACET 切换锚点行（switch_facet 工具在 SOUL.md 中查找此字符串作为分界点）
# 锚点行及之前的内容保留，之后的内容会被替换为目标 facet 文件内容
# 注意！如果在 SOUL.md 中有多个相同的锚点行内容，会使用检索到的第一个（最上边）的锚点行
# 默认值：## **警告** FACET 模组 内容切换时，必须在这一行之后执行，不可覆盖替换这一行之前的内容。
# 示例：BELLDANDY_FACET_ANCHOR=<!-- FACET_ANCHOR -->
# BELLDANDY_FACET_ANCHOR=

# ========================================
# 其他配置
# ========================================
# 自动打开浏览器（启动时）
# AUTO_OPEN_BROWSER=true

# Setup 向导 Token（自动打开浏览器的魔法链接）
# SETUP_TOKEN=

# ========================================
# Tailscale 远程访问（可选）
# ========================================
# 从 https://login.tailscale.com/admin/settings/keys 获取 Auth Key
# 使用方法: docker-compose --profile tailscale up -d
# TAILSCALE_AUTH_KEY=tskey-auth-xxxxx
# TAILSCALE_EXTRA_ARGS=--ssh  # 启用 SSH 访问（可选）





BELLDANDY_AGENT_PROVIDER=openai
#用中转代理调用claude-opus等模型时启用下方这条设置,Anthropic官方不需启用
# BELLDANDY_AGENT_PROTOCOL=anthropic

# 流式输出（默认 true）
BELLDANDY_OPENAI_STREAM=true

# OpenAI 线路协议：chat_completions（默认）| responses
# 使用 responses 的 gpt-5.3-codex 时通常需要设置为 responses
BELLDANDY_OPENAI_WIRE_API=chat_completions

# MinMax-M2.5配置：
BELLDANDY_OPENAI_API_KEY=你的API_KEY
BELLDANDY_OPENAI_BASE_URL=https://api.minimaxi.com/v1
BELLDANDY_OPENAI_MODEL=MiniMax-M2.5

# 如果 BELLDANDY_OPENAI_BASE_URL 包含 anthropic.com，prompt caching 会自动启用。
# 也可以显式设置 BELLDANDY_AGENT_PROTOCOL=anthropic
# OpenAI 协议配置（BELLDANDY_AGENT_PROVIDER=openai 时需要）
# 支持 OpenAI、Gemini、DeepSeek、Ollama 等兼容服务
# claude模型配置：
# BELLDANDY_OPENAI_API_KEY="你的API_KEY"
# BELLDANDY_OPENAI_BASE_URL="https://api.anthropic.com"
# BELLDANDY_OPENAI_MODEL="claude-opus-4-6"

# 图形、视屏理解时用以下kimi-k2.5模型配置：
# BELLDANDY_OPENAI_API_KEY="你的API_KEY"
# BELLDANDY_OPENAI_BASE_URL="https://api.moonshot.cn/v1"
# BELLDANDY_OPENAI_MODEL="kimi-k2.5"

# ------ 记忆与向量检索 ------
# 启用向量搜索（需要 Embedding 模型）
# 模型会自动下载并保存到 ~/.belldandy/models 文件夹中
BELLDANDY_EMBEDDING_ENABLED=true
# Embedding 提供商选择: openai | local (默认是 openai)
# BELLDANDY_EMBEDDING_PROVIDER=openai
# 本地模型名称 (仅当 provider=local 时生效)
# BELLDANDY_EMBEDDING_PROVIDER=local
# BELLDANDY_EMBEDDING_PROVIDER=openai
BELLDANDY_EMBEDDING_PROVIDER=openai
# BELLDANDY_LOCAL_EMBEDDING_MODEL=BAAI/bge-m3
# 如果您的 Embedding 服务使用不同的 Key/BaseURL，请在此配置；否则默认使用上方的通用配置
BELLDANDY_EMBEDDING_OPENAI_API_KEY="你的API_KEY"
BELLDANDY_EMBEDDING_OPENAI_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"
BELLDANDY_EMBEDDING_MODEL="text-embedding-v4"

# ------ 记忆系统增强（Phase M-Next）目前默认配置如下 ------
# L0 摘要层（默认关闭）
BELLDANDY_MEMORY_SUMMARY_ENABLED=true
BELLDANDY_MEMORY_SUMMARY_MODEL="moonshot-v1-32k-vision-preview"
BELLDANDY_MEMORY_SUMMARY_BASE_URL="https://api.moonshot.cn/v1"
BELLDANDY_MEMORY_SUMMARY_API_KEY="你的API_KEY"

# 会话记忆自动提取（默认关闭）
BELLDANDY_MEMORY_EVOLUTION_ENABLED=true
BELLDANDY_MEMORY_EVOLUTION_MIN_MESSAGES=8
BELLDANDY_MEMORY_EVOLUTION_MODEL="moonshot-v1-32k-vision-preview"
BELLDANDY_MEMORY_EVOLUTION_BASE_URL="https://api.moonshot.cn/v1"
BELLDANDY_MEMORY_EVOLUTION_API_KEY="你的API_KEY"

# 源路径聚合检索（默认关闭）
BELLDANDY_MEMORY_DEEP_RETRIEVAL=true

# 飞书相关配置
BELLDANDY_FEISHU_APP_ID=
BELLDANDY_FEISHU_APP_SECRET=

BELLDANDY_HEARTBEAT_INTERVAL="10m"

# ------ QQ 渠道（可选）------
# 机器人QQ号：3889764917
# AppSecret(机器人密钥）：evDVo7Qk4Pk6SpCayMlAa0RsKmFiBf9e
BELLDANDY_QQ_APP_ID=
BELLDANDY_QQ_APP_SECRET=
# QQ 渠道绑定的 Agent Profile ID（可选，默认使用 default Agent）
BELLDANDY_QQ_AGENT_ID=default
# 默认开启沙箱环境 (true/false)
BELLDANDY_QQ_SANDBOX=true

# ------ Discord 渠道（可选）------
# 申请流程：https://discord.com/developers/applications
# 1. 创建 Application → Bot 页面 → Reset Token 获取 Bot Token
# 2. 开启 MESSAGE CONTENT INTENT（必须）
# 3. OAuth2 → URL Generator → bot → 勾选权限 → 邀请到服务器
BELLDANDY_DISCORD_ENABLED=true
BELLDANDY_DISCORD_BOT_TOKEN=
# BELLDANDY_DISCORD_DEFAULT_CHANNEL_ID=

# Aliyun DashScope TTS
# 请在此处填入你的 API Key
DASHSCOPE_API_KEY=你的API_KEY
# 启用语音模式（服务端自动将 Agent 回复转为语音，true/false，默认 false）
BELLDANDY_TTS_ENABLED=false
# TTS 提供商: dashscope | edge (free) | openai
BELLDANDY_TTS_PROVIDER="dashscope"
# 语音 ID: DashScope: Cherry/Chelsie | Edge: zh-CN-XiaoxiaoNeural | OpenAI: alloy
BELLDANDY_TTS_VOICE="Chelsie"

# ------ 语音识别 (STT) 配置 ------
# Provider: openai | groq | dashscope (默认 openai)
BELLDANDY_STT_PROVIDER=dashscope
# 语言提示 (默认 zh)
BELLDANDY_STT_LANGUAGE=zh


# Token 消耗上传到 office.goddess.ai（默认关闭）
# 作用：把每次新增的 token 消耗（delta）上报给 office 的 /api/internal/token-usage
# 可让你的office.goddess.ai社区账号获得等级提升
# 使用步骤（通俗版）：
# 1) 先把 ENABLED 改成 true
# 2) URL 填 office 后端地址（通常是 http://127.0.0.1:3001/api/internal/token-usage）
# 3) APIKEY 填“该用户在 office.goddess.ai 里生成的 API Key 明文（gro_...）”
# 4) Belldandy 会自动带请求头：Authorization: Bearer <APIKEY>
# 5) office 后端会用这个 API Key 反查归属用户并累计到该用户账号
BELLDANDY_TOKEN_USAGE_UPLOAD_ENABLED=true
# 接收端接口（office 内部路由）
BELLDANDY_TOKEN_USAGE_UPLOAD_URL=https://recwcppxiamd.sealosgzg.site/api/internal/token-usage
# 上传鉴权 API Key（推荐：每用户独立 key，便于单独吊销）
BELLDANDY_TOKEN_USAGE_UPLOAD_APIKEY=你的office.goddess.ai社区API Key
# 上传超时（毫秒，默认 3000）
BELLDANDY_TOKEN_USAGE_UPLOAD_TIMEOUT_MS=15000

# 模型调用设置
BELLDANDY_OPENAI_MAX_RETRIES=1
BELLDANDY_OPENAI_RETRY_BACKOFF_MS=300
BELLDANDY_PRIMARY_WARMUP_ENABLED=true
BELLDANDY_PRIMARY_WARMUP_TIMEOUT_MS=8000
BELLDANDY_PRIMARY_WARMUP_COOLDOWN_MS=60000

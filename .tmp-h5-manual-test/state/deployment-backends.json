      "observability": { "logMode": "docker" }
    },
    {
      "id": "ssh-burst",
      "label": "SSH Burst",
      "backend": "ssh",
      "enabled": true,
      "runtime": { "host": "gateway.internal", "user": "admin", "port": 2222 },
      "workspace": { "mode": "sync", "remotePath": "/srv/star-sanctuary" },
      "credentials": { "mode": "ssh_agent" },
      "observability": { "logMode": "ssh" }
    }
  ]

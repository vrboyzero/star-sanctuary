{
  "version": 1,
  "selectedProfileId": "docker-main",
  "profiles": [
    {
      "id": "local-default",
      "label": "Local Default",
      "backend": "local",
      "enabled": true,
      "workspace": { "mode": "direct" },
      "credentials": { "mode": "inherit_env" },
      "observability": { "logMode": "local" }
    },
    {
      "id": "docker-main",
      "label": "Docker Main",
      "backend": "docker",
      "enabled": true,
